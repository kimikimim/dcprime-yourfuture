---
import GlossaryLayout from '../layouts/GlossaryLayout.astro';

const TRACKS = [
  {
    title: '생산관리 / 제조공학 트랙',
    subtitle: 'Production Management & Manufacturing Engineering',
    careers: ['제조 대기업의 생산관리(PM) 및 SCM 부서', '글로벌 물류 기업'],
    courses: [
      {
        name: '생산계획 및 통제',
        nameEn: 'Production Planning & Control',
        year: '3학년 1학기',
        terms: [
          { ko: '린 생산방식', en: 'Lean Manufacturing', desc: '낭비를 최소화하고 필요한 만큼만 생산하는 도요타 생산방식에서 비롯된 생산 철학. 재고, 대기시간, 불량 등 7가지 낭비 제거를 추구.' },
          { ko: '경제적 주문량', en: 'Economic Order Quantity (EOQ)', formula: 'Q^* = \\sqrt{\\frac{2DS}{H}}', desc: '주문 비용과 재고 유지 비용의 합을 최소화하는 최적 주문량을 구하는 재고관리 모델.' },
          { ko: '작업 스케줄링', en: 'Job Scheduling', desc: '한정된 자원(기계, 인력)에 여러 작업을 어떤 순서로 배정할지 결정하는 문제. 납기 준수와 생산성 향상이 목표.' },
          { ko: '공급사슬관리', en: 'Supply Chain Management (SCM)', desc: '원자재 조달부터 생산, 유통, 고객 전달까지 전체 흐름을 계획하고 조율하는 경영 기법.' },
          { ko: '공장 배치론', en: 'Facility Layout Planning', desc: '생산 설비와 작업 공간을 효율적으로 배치해 자재 이동 거리와 생산 흐름을 최적화하는 기법.' },
        ],
      },
      {
        name: '최적화이론 (OR)',
        nameEn: 'Operations Research',
        year: '2학년 2학기',
        terms: [
          { ko: '선형계획법', en: 'Linear Programming', desc: '선형 제약 조건 아래에서 선형 목적함수를 최대/최소화하는 최적화 기법. 심플렉스법으로 해를 구하며, 생산·물류 계획에 널리 쓰임.' },
          { ko: '정수계획법', en: 'Integer Programming', desc: '변수가 정수 값만 가져야 하는 최적화 문제. 분기한정법(Branch and Bound) 등으로 해결하며 스케줄링, 배치 문제에 활용됨.' },
          { ko: '네트워크 최적화', en: 'Network Optimization', desc: '노드와 간선으로 이루어진 네트워크에서 최단 경로, 최대 유량 등을 구하는 문제. 물류, 통신망 설계에 응용됨.' },
          { ko: '동적계획법', en: 'Dynamic Programming', desc: '복잡한 의사결정 문제를 단계별 부분 문제로 나누어 순차적으로 최적해를 구하는 기법. 재고, 설비투자 등 다단계 의사결정에 활용.' },
        ],
      },
    ],
  },
  {
    title: '인간공학 / UX 디자인 트랙',
    subtitle: 'Human Factors & UX Design',
    careers: ['IT 기업 및 제조사의 UX 리서처', '가전/자동차 내장 UI/UX 기획 부서'],
    courses: [
      {
        name: '인간공학 및 UX디자인',
        nameEn: 'Human Factors & UX Design',
        year: '4학년 1학기',
        terms: [
          { ko: '인간공학', en: 'Ergonomics', desc: '사람의 신체적·인지적 특성에 맞춰 제품이나 작업환경을 설계하는 학문. 안전과 효율, 편의성을 동시에 추구함.' },
          { ko: '작업연구', en: 'Time & Motion Study', desc: '작업 동작과 소요 시간을 분석해 표준 작업 시간을 정하고 비효율을 제거하는 산업공학의 고전적 기법.' },
          { ko: '사용자 경험(UX) 데이터 분석', en: 'UX Data Analysis', desc: '사용자의 행동 로그, 클릭 패턴 등을 분석해 인터페이스 개선점을 찾아내는 기법.' },
          { ko: '인지공학', en: 'Cognitive Engineering', desc: '인간의 인지적 정보처리 과정을 이해하고, 이를 바탕으로 오류를 줄이는 인터페이스와 시스템을 설계하는 학문.' },
        ],
      },
    ],
  },
];

const RELATED_MAJORS = [
  { href: '/industrial/business-analytics', title: '데이터사이언스/BA', subtitle: 'Data Science & Business Analytics' },
  { href: '/industrial/management', title: '경영공학', subtitle: 'Engineering Management' },
  { href: '/industrial/quality', title: '품질경영/신뢰성공학', subtitle: 'Quality & Reliability Engineering' },
  { href: '/industrial/logistics', title: '물류/유통시스템공학', subtitle: 'Logistics Engineering' },
  { href: '/industrial/systems', title: '시스템공학', subtitle: 'Systems Engineering' },
];
---

<GlossaryLayout
  metaTitle="Your Future - 산업공학 전공 맛보기 | 대치프라임"
  metaDescription="산업공학과 공통 트랙(생산관리, 인간공학/UX)과 5개 세부 학과를 재구성한 전공 맛보기 페이지입니다."
  heading="산업공학"
  descriptionPrefix={`산업공학과에 입학하면 아래 생산관리·제조, 인간공학·UX 트랙을 공통으로 배우고, 이후 세부 학과(데이터사이언스/BA, 경영공학, 품질경영/신뢰성, 물류/유통, 시스템공학)로 나뉘어 전공을 심화합니다.`}
  searchPlaceholder="개념 이름으로 검색 (예: EOQ, 인간공학, 선형계획법)"
  tracks={TRACKS}
  relatedMajors={RELATED_MAJORS}
/>
