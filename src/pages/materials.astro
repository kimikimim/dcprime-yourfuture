---
import GlossaryLayout from '../layouts/GlossaryLayout.astro';

const TRACKS = [
  {
    title: '결정구조 및 상변태',
    subtitle: 'Crystal Structure & Phase Transformation',
    courses: [
      {
        name: '결정구조론',
        nameEn: 'Crystal Structure',
        year: '2학년 1학기',
        terms: [
          { ko: '브라베 격자', en: 'Bravais Lattice', desc: '결정을 이루는 원자 배열의 반복 단위를 기술하는 14가지 격자 유형. 재료의 물성이 결정 구조에 크게 의존함을 보여주는 출발점.' },
          { ko: '밀러 지수', en: 'Miller Indices', desc: '결정 안의 특정 면이나 방향을 나타내는 세 정수 표기법. 결정면에 따라 물성이 달라지는 이방성을 다룰 때 사용.' },
          { ko: '전위', en: 'Dislocation', desc: '결정 격자 안의 선 결함. 금속이 소성 변형(영구 변형)을 일으키는 주된 메커니즘으로, 전위의 이동이 곧 소성 변형임.' },
          { ko: '점결함', en: 'Point Defects', desc: '결정 격자에서 원자가 빠지거나(공공) 다른 자리에 끼어들거나(침입형) 하는 0차원 결함. 확산과 물성에 큰 영향을 줌.' },
        ],
      },
      {
        name: '상변태론',
        nameEn: 'Phase Transformation',
        year: '3학년 1학기',
        terms: [
          { ko: '상평형도', en: 'Phase Diagram', desc: '온도, 조성 등에 따라 물질이 어떤 상(고체/액체/기체, 또는 결정 구조)으로 존재하는지를 나타낸 그림. 합금 설계의 지도 역할.' },
          { ko: '철-탄소 상태도', en: 'Fe-C Phase Diagram', desc: '철과 탄소 함량에 따른 강(steel)과 주철의 미세조직 변화를 나타낸 상태도. 열처리 설계의 기본 참고자료.' },
          { ko: 'TTT 곡선', en: 'Time-Temperature-Transformation Diagram', desc: '특정 온도에서 시간에 따라 상변태가 얼마나 진행되는지를 나타낸 도표. 담금질, 뜨임 등 열처리 공정 설계에 사용.' },
          { ko: '확산', en: "Diffusion (Fick's Laws)", desc: '농도 차이에 의해 원자가 이동하는 현상. 열처리, 도핑, 상변태 등 재료 공정 전반의 속도를 지배함.' },
        ],
      },
      {
        name: '재료열역학',
        nameEn: 'Materials Thermodynamics',
        year: '3학년 1학기',
        terms: [
          { ko: '깁스 상률', en: 'Gibbs Phase Rule', formula: 'F = C - P + 2', desc: '평형 상태에서 자유도(F), 성분 수(C), 상의 수(P) 사이의 관계를 나타내는 규칙. 상평형도를 해석하는 기본 원리.' },
          { ko: '자유에너지 도표', en: 'Free Energy Diagrams', desc: '온도별로 각 상의 자유에너지를 조성의 함수로 나타낸 그래프. 어떤 온도·조성에서 어떤 상이 안정한지를 결정함.' },
          { ko: '확산쌍', en: 'Diffusion Couples', desc: '서로 다른 두 재료를 접합해 원자가 서로 확산해 들어가는 정도를 관찰함으로써 확산계수를 측정하는 실험 기법.' },
        ],
      },
    ],
  },
  {
    title: '재료물성',
    subtitle: 'Materials Properties',
    courses: [
      {
        name: '기계적물성',
        nameEn: 'Mechanical Properties of Materials',
        year: '3학년 1학기',
        terms: [
          { ko: '응력-변형률 곡선', en: 'Stress-Strain Curve', desc: '재료에 하중을 가하며 측정한 응력과 변형률의 관계 곡선. 탄성계수, 항복강도, 인장강도 등 대부분의 기계적 물성을 읽어낼 수 있음.' },
          { ko: '항복강도', en: 'Yield Strength', desc: '재료가 탄성 변형을 넘어 영구적인 소성 변형을 시작하는 응력 값. 구조 설계의 핵심 기준.' },
          { ko: '인성', en: 'Toughness', desc: '재료가 파괴되기까지 흡수할 수 있는 에너지의 양. 강도는 높지만 인성이 낮으면 쉽게 깨질 수 있음(취성).' },
          { ko: '경도', en: 'Hardness', desc: '재료 표면이 국부적인 소성 변형(눌림, 긁힘)에 저항하는 정도. 비커스, 로크웰 등 다양한 시험법으로 측정.' },
          { ko: '크리프', en: 'Creep', desc: '항복강도보다 낮은 응력이라도 고온에서 장시간 지속되면 서서히 영구 변형이 누적되는 현상. 터빈 블레이드 등 고온 부품 설계에서 중요.' },
        ],
      },
      {
        name: '전자·광학재료',
        nameEn: 'Electronic & Optical Materials',
        year: '3학년 2학기',
        terms: [
          { ko: '밴드갭', en: 'Band Gap', desc: '전자가 존재할 수 없는 전도띠와 가전자띠 사이의 에너지 간격. 물질이 도체, 반도체, 절연체 중 무엇인지, 어떤 색의 빛을 내는지를 결정함.' },
          { ko: '유전율', en: 'Permittivity (Dielectric Constant)', desc: '물질이 전기장에 반응해 분극되는 정도를 나타내는 값. 커패시터, 절연체 재료 선정의 핵심 지표.' },
          { ko: '압전 효과', en: 'Piezoelectric Effect', desc: '특정 결정에 기계적 응력을 가하면 전압이 발생하고, 반대로 전압을 가하면 변형이 일어나는 현상. 센서와 액추에이터에 활용.' },
          { ko: '초전도', en: 'Superconductivity', desc: '특정 임계온도 이하에서 전기 저항이 완전히 0이 되는 현상. MRI, 자기부상열차 등 초강력 전자석 응용의 핵심.' },
        ],
      },
      {
        name: '부식 및 표면공학',
        nameEn: 'Corrosion & Surface Engineering',
        year: '3학년 2학기',
        terms: [
          { ko: '전기화학적 부식', en: 'Electrochemical Corrosion', desc: '금속이 전해질 환경에서 산화(양극)와 환원(음극) 반응을 통해 서서히 소모되는 현상. 갈바닉 부식, 공식 부식 등 다양한 형태가 있음.' },
          { ko: '부동태 피막', en: 'Passive Film', desc: '금속 표면에 형성되는 얇고 치밀한 산화막으로, 추가적인 부식 진행을 억제하는 보호층. 스테인리스강의 내식성이 대표적 예.' },
        ],
      },
    ],
  },
  {
    title: '재료공정',
    subtitle: 'Materials Processing',
    courses: [
      {
        name: '재료공정',
        nameEn: 'Materials Processing',
        year: '4학년 1학기',
        terms: [
          { ko: '소결', en: 'Sintering', desc: '분말 형태의 재료를 녹는점 이하 고온에서 압축·가열해 입자끼리 결합시켜 고체 덩어리로 만드는 공정. 세라믹, 분말야금의 핵심 공정.' },
          { ko: '담금질과 뜨임', en: 'Quenching & Tempering', desc: '고온에서 급랭시켜 경도를 높이는 담금질과, 이후 적당히 재가열해 취성을 줄이는 뜨임을 조합한 열처리 공정.' },
          { ko: '박막 증착', en: 'Thin Film Deposition', desc: '기판 위에 원자/분자 단위로 얇은 막을 형성하는 공정. 반도체, 디스플레이, 코팅 산업 전반의 핵심 기술.' },
          { ko: '복합재료', en: 'Composite Materials', desc: '두 가지 이상의 서로 다른 재료를 결합해 각 재료의 장점을 살린 새로운 물성을 얻는 재료. 탄소섬유강화플라스틱(CFRP)이 대표적.' },
        ],
      },
      {
        name: '세라믹재료공학',
        nameEn: 'Ceramic Materials Engineering',
        year: '3학년 2학기',
        terms: [
          { ko: '세라믹의 결합 특성', en: 'Ionic & Covalent Bonding in Ceramics', desc: '세라믹은 주로 이온결합과 공유결합으로 이루어져 금속보다 단단하고 녹는점이 높지만 전위 이동이 어려움.' },
          { ko: '세라믹의 취성', en: 'Brittleness of Ceramics', desc: '세라믹이 소성 변형 없이 갑자기 파괴되는 성질. 미세한 균열이 응력집중을 일으켜 쉽게 파괴로 이어짐.' },
        ],
      },
      {
        name: '고분자재료공학',
        nameEn: 'Polymer Materials Engineering',
        year: '3학년 2학기',
        terms: [
          { ko: '고분자 사슬 구조', en: 'Polymer Chain Structure', desc: '선형, 가지형, 그물형 등 고분자 사슬이 배열되는 방식. 사슬 구조에 따라 강도, 유연성 등 물성이 크게 달라짐.' },
          { ko: '열가소성과 열경화성', en: 'Thermoplastics & Thermosets', desc: '가열하면 녹아 재성형이 가능한 열가소성 고분자와, 한 번 굳으면 다시 녹지 않는 열경화성 고분자의 차이.' },
        ],
      },
    ],
  },
  {
    title: '나노 및 바이오재료',
    subtitle: 'Nano & Biomaterials',
    courses: [
      {
        name: '나노재료공학',
        nameEn: 'Nanomaterials Engineering',
        year: '4학년 1학기',
        terms: [
          { ko: '양자점', en: 'Quantum Dots', desc: '나노미터 크기의 반도체 입자로, 크기에 따라 발광 파장이 달라지는 양자구속효과를 나타냄. 디스플레이, 바이오 이미징에 활용.' },
          { ko: '나노입자 합성', en: 'Nanoparticle Synthesis', desc: '화학적 환원, 졸-겔법 등을 통해 나노미터 크기의 입자를 제어된 형태와 크기로 만들어내는 기법.' },
          { ko: '표면적 대 부피비 효과', en: 'Surface-to-Volume Ratio Effect', desc: '입자가 작아질수록 표면적이 부피에 비해 급격히 커져 반응성, 촉매 활성 등이 크게 달라지는 나노 스케일 고유의 현상.' },
        ],
      },
      {
        name: '바이오재료공학',
        nameEn: 'Biomaterials Engineering',
        year: '4학년 2학기',
        terms: [
          { ko: '생체적합성', en: 'Biocompatibility', desc: '재료가 인체 조직과 접촉했을 때 면역거부반응이나 독성을 일으키지 않고 잘 어우러지는 성질. 의료용 재료 선택의 최우선 기준.' },
          { ko: '임플란트 재료', en: 'Implant Materials', desc: '인공 관절, 치아 임플란트 등 인체에 이식되는 티타늄 합금, 세라믹 등의 재료. 강도와 생체적합성을 동시에 만족해야 함.' },
        ],
      },
    ],
  },
];
---

<GlossaryLayout
  metaTitle="Your Future - 신소재공학 전공 맛보기 | 대치프라임"
  metaDescription="대학 신소재공학과 커리큘럼을 기반으로 재구성한 전공 맛보기 페이지입니다."
  heading="신소재공학"
  descriptionPrefix={`신소재공학과에 가면 실제로 배우게 될 과목들을 트랙별로 묶어뒀습니다. 과목을 눌러보면 그 안에서 다루는 핵심 개념이 펼쳐져요.`}
  searchPlaceholder="개념 이름으로 검색 (예: 전위, 밴드갭, 크리프)"
  tracks={TRACKS}
/>
