---
import GlossaryLayout from '../layouts/GlossaryLayout.astro';

const CATEGORIES = [
  {
    title: '결정구조',
    subtitle: 'Crystal Structure',
    terms: [
      { ko: '브라베 격자', en: 'Bravais Lattice', desc: '결정을 이루는 원자 배열의 반복 단위를 기술하는 14가지 격자 유형. 재료의 물성이 결정 구조에 크게 의존함을 보여주는 출발점.' },
      { ko: '밀러 지수', en: 'Miller Indices', desc: '결정 안의 특정 면이나 방향을 나타내는 세 정수 표기법. 결정면에 따라 물성이 달라지는 이방성을 다룰 때 사용.' },
      { ko: '전위', en: 'Dislocation', desc: '결정 격자 안의 선 결함. 금속이 소성 변형(영구 변형)을 일으키는 주된 메커니즘으로, 전위의 이동이 곧 소성 변형임.' },
      { ko: '점결함', en: 'Point Defects', desc: '결정 격자에서 원자가 빠지거나(공공) 다른 자리에 끼어들거나(침입형) 하는 0차원 결함. 확산과 물성에 큰 영향을 줌.' },
    ],
  },
  {
    title: '상변태 및 상평형',
    subtitle: 'Phase Transformation & Equilibrium',
    terms: [
      { ko: '상평형도', en: 'Phase Diagram', desc: '온도, 조성 등에 따라 물질이 어떤 상(고체/액체/기체, 또는 결정 구조)으로 존재하는지를 나타낸 그림. 합금 설계의 지도 역할.' },
      { ko: '철-탄소 상태도', en: 'Fe-C Phase Diagram', desc: '철과 탄소 함량에 따른 강(steel)과 주철의 미세조직 변화를 나타낸 상태도. 열처리 설계의 기본 참고자료.' },
      { ko: 'TTT 곡선', en: 'Time-Temperature-Transformation Diagram', desc: '특정 온도에서 시간에 따라 상변태가 얼마나 진행되는지를 나타낸 도표. 담금질, 뜨임 등 열처리 공정 설계에 사용.' },
      { ko: '확산', en: 'Diffusion (Fick\'s Laws)', desc: '농도 차이에 의해 원자가 이동하는 현상. 열처리, 도핑, 상변태 등 재료 공정 전반의 속도를 지배함.' },
    ],
  },
  {
    title: '기계적 물성',
    subtitle: 'Mechanical Properties',
    terms: [
      { ko: '응력-변형률 곡선', en: 'Stress-Strain Curve', desc: '재료에 하중을 가하며 측정한 응력과 변형률의 관계 곡선. 탄성계수, 항복강도, 인장강도 등 대부분의 기계적 물성을 읽어낼 수 있음.' },
      { ko: '항복강도', en: 'Yield Strength', desc: '재료가 탄성 변형을 넘어 영구적인 소성 변형을 시작하는 응력 값. 구조 설계의 핵심 기준.' },
      { ko: '인성', en: 'Toughness', desc: '재료가 파괴되기까지 흡수할 수 있는 에너지의 양. 강도는 높지만 인성이 낮으면 쉽게 깨질 수 있음(취성).' },
      { ko: '경도', en: 'Hardness', desc: '재료 표면이 국부적인 소성 변형(눌림, 긁힘)에 저항하는 정도. 비커스, 로크웰 등 다양한 시험법으로 측정.' },
      { ko: '크리프', en: 'Creep', desc: '항복강도보다 낮은 응력이라도 고온에서 장시간 지속되면 서서히 영구 변형이 누적되는 현상. 터빈 블레이드 등 고온 부품 설계에서 중요.' },
    ],
  },
  {
    title: '전자 및 광학 재료',
    subtitle: 'Electronic & Optical Materials',
    terms: [
      { ko: '밴드갭', en: 'Band Gap', desc: '전자가 존재할 수 없는 전도띠와 가전자띠 사이의 에너지 간격. 물질이 도체, 반도체, 절연체 중 무엇인지, 어떤 색의 빛을 내는지를 결정함.' },
      { ko: '유전율', en: 'Permittivity (Dielectric Constant)', desc: '물질이 전기장에 반응해 분극되는 정도를 나타내는 값. 커패시터, 절연체 재료 선정의 핵심 지표.' },
      { ko: '압전 효과', en: 'Piezoelectric Effect', desc: '특정 결정에 기계적 응력을 가하면 전압이 발생하고, 반대로 전압을 가하면 변형이 일어나는 현상. 센서와 액추에이터에 활용.' },
      { ko: '초전도', en: 'Superconductivity', desc: '특정 임계온도 이하에서 전기 저항이 완전히 0이 되는 현상. MRI, 자기부상열차 등 초강력 전자석 응용의 핵심.' },
    ],
  },
  {
    title: '재료 합성 및 공정',
    subtitle: 'Materials Processing',
    terms: [
      { ko: '소결', en: 'Sintering', desc: '분말 형태의 재료를 녹는점 이하 고온에서 압축·가열해 입자끼리 결합시켜 고체 덩어리로 만드는 공정. 세라믹, 분말야금의 핵심 공정.' },
      { ko: '담금질과 뜨임', en: 'Quenching & Tempering', desc: '고온에서 급랭시켜 경도를 높이는 담금질과, 이후 적당히 재가열해 취성을 줄이는 뜨임을 조합한 열처리 공정.' },
      { ko: '박막 증착', en: 'Thin Film Deposition', desc: '기판 위에 원자/분자 단위로 얇은 막을 형성하는 공정. 반도체, 디스플레이, 코팅 산업 전반의 핵심 기술.' },
      { ko: '복합재료', en: 'Composite Materials', desc: '두 가지 이상의 서로 다른 재료를 결합해 각 재료의 장점을 살린 새로운 물성을 얻는 재료. 탄소섬유강화플라스틱(CFRP)이 대표적.' },
    ],
  },
];
---

<GlossaryLayout
  metaTitle="Your Future - 신소재공학 전공 맛보기 | 대치프라임"
  metaDescription="대학 신소재공학과에서 배우는 핵심 개념을 미리 만나보는 전공 맛보기 페이지입니다."
  heading="신소재공학 전공 맛보기"
  descriptionPrefix={`신소재공학과에 가면 실제로 배우게 될 결정구조, 상변태, 물성, 공정의 핵심 개념들을 모아뒀습니다. 다 이해할 필요는 없고, 전공의 결을 느껴보는 용도예요.`}
  searchPlaceholder="개념 이름으로 검색 (예: 전위, 밴드갭, 크리프)"
  categories={CATEGORIES}
/>
