    careers: ['병원간호사', '간호대학 조교', '간호연구원'],
    courses: [
      {
        name: '기본간호학',
        nameEn: 'Fundamentals of Nursing',
        year: '1~2학년',
        terms: [
          { ko: '활력징후 측정', en: 'Vital Signs Assessment', desc: '체온, 맥박, 호흡, 혈압 등 생명 유지에 필수적인 지표를 측정하고 평가하는 간호의 가장 기본적인 술기.', example: '입원하면 간호사가 매일 정해진 시간에 체온과 혈압을 재는 이유.' },
