---

<GlossaryLayout
  metaTitle="Your Future - 화학공학 전공 맛보기 | 대치프라임"
  metaDescription="대학 화학공학과 커리큘럼을 기반으로 재구성한 전공 맛보기 페이지입니다."
  heading="화학공학"
  descriptionPrefix={`화학공학과에 가면 실제로 배우게 될 과목들을 트랙별로 묶어뒀습니다. 과목을 눌러보면 그 안에서 다루는 핵심 개념이 펼쳐져요.`}
  searchPlaceholder="개념 이름으로 검색 (예: 아레니우스, 증류, CSTR)"
  tracks={TRACKS}
/>
