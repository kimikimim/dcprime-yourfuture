---

<GlossaryLayout
  metaTitle="Your Future - 항공우주공학과 전공 맛보기 | 대치프라임"
  metaDescription="대기권 내를 비행하는 항공기와 대기권 밖을 비행하는 우주선·발사체를 연구하는 항공우주공학과 커리큘럼을 재구성한 전공 맛보기 페이지입니다."
  heading="항공우주공학과"
  descriptionPrefix={`지구 대기권 내를 비행하는 항공기(Aeronautics)와 대기권 밖을 비행하는 우주선 및 발사체(Astronautics)를 연구하는 첨단 공학 분야예요. 5개 세부 트랙으로 나누어뒀습니다.`}
  searchPlaceholder="개념 이름으로 검색 (예: 로켓추진, SLAM, 위성탑재체)"
  tracks={TRACKS}
/>
