---
import GlossaryLayout from '../../layouts/GlossaryLayout.astro';

const TRACKS = [
  {
    title: '경영공학과',
    subtitle: 'Engineering Management',
    careers: ['글로벌 전략 컨설팅 펌', '기업 기획실', '벤처캐피탈(VC)', '증권사 리서치 센터'],
    courses: [
      {
        name: '경영공학',
        nameEn: 'Engineering Management',
        year: '4학년 1학기',
        terms: [
          { ko: '의사결정분석', en: 'Decision Analysis', formula: 'EV = \\sum p_i \\times v_i', desc: '불확실한 상황에서 각 대안이 가져올 결과와 그 발생 확률 $p_i$을 의사결정나무로 구조화하고, 각 대안의 기대값 $EV$(발생 확률과 결과값의 곱의 합)를 계산해 가장 유리한 선택지를 체계적으로 고르는 방법론.', example: '신제품 출시 여부를 성공/실패 확률과 각각의 예상 수익으로 계산한 기대값으로 결정하는 것.' },
          { ko: '게임이론', en: 'Game Theory', desc: '한 사람의 최선의 선택이 상대방의 선택에 따라 달라지는 상황을 수학적으로 분석하는 이론. 각 참가자가 상대의 전략을 예상한 상태에서 자신의 전략을 바꿀 유인이 없는 균형 상태(내쉬균형)를 찾아내, 가격 경쟁이나 경매 입찰처럼 서로 영향을 주고받는 전략적 상황을 예측함.', example: '두 통신사가 요금제 가격을 서로의 대응을 예측하며 정하는 가격 경쟁 상황을 분석하는 것.' },
          { ko: '공학경제학', en: 'Engineering Economics', formula: 'NPV = \\sum \\frac{CF_t}{(1+r)^t}', desc: '미래에 발생할 현금흐름 $CF_t$은 시간이 지날수록 화폐 가치가 할인되므로, 할인율 $r$을 적용해 모두 현재 시점 가치로 환산한 순현재가치(NPV)를 계산해 여러 투자안의 경제성을 같은 기준으로 비교하는 학문.', example: '새 생산설비 도입이 투자 비용 대비 미래에 충분한 이익을 낼지 NPV로 판단하는 것.' },
          { ko: '기술경영', en: 'Management of Technology (MOT)', desc: '기술을 단순한 도구가 아니라 기업의 경쟁우위를 만드는 전략적 자산으로 보고, 어떤 기술에 얼마나 R&D 투자를 할지 우선순위를 정하고 그 기술이 언제 어떤 제품으로 이어질지 로드맵을 그려 관리하는 경영 분야.', example: '반도체 기업이 다음 세대 공정 기술 개발에 R&D 예산을 어떻게 배분할지 결정하는 기술 로드맵.' },
          { ko: '재무 리스크 관리', en: 'Financial Risk Management', desc: '시장 가격 변동으로 인한 손실 위험(시장리스크), 거래상대방이 채무를 이행하지 못할 위험(신용리스크), 내부 프로세스 오류로 인한 위험(운영리스크) 등을 확률·통계 모델로 정량화해 손실 한도를 정하고 관리하는 기법.', example: '은행이 대출 포트폴리오의 예상 손실액을 통계 모델로 미리 계산해 대비하는 것.' },
          { ko: '투자 타당성 분석', en: 'Investment Feasibility Analysis', desc: '새 사업·설비 투자에서 발생할 모든 미래 현금흐름을 현재가치로 환산한 순현재가치(NPV)가 0보다 큰지, 또는 NPV를 0으로 만드는 할인율(내부수익률, IRR)이 기업의 최소 요구수익률보다 높은지를 기준으로 투자 여부를 판단하는 분석.', example: '새 공장 건설이 초기 투자비를 회수하고도 충분한 수익을 낼지 사전에 검증하는 것.' },
        ],
      },
    ],
  },
];

const RELATED_MAJORS = [
  { href: '/industrial', title: '산업공학', subtitle: 'Industrial Engineering' },
  { href: '/industrial/business-analytics', title: '데이터사이언스/BA', subtitle: 'Data Science & Business Analytics' },
  { href: '/industrial/quality', title: '품질경영/신뢰성공학', subtitle: 'Quality & Reliability Engineering' },
  { href: '/industrial/logistics', title: '물류/유통시스템공학', subtitle: 'Logistics Engineering' },
  { href: '/industrial/systems', title: '시스템공학', subtitle: 'Systems Engineering' },
];
---

<GlossaryLayout
  metaTitle="Your Future - 경영공학 전공 맛보기 | 대치프라임"
  metaDescription="공학경제학, 기술경영, 재무리스크관리까지 경영공학과 커리큘럼을 재구성한 전공 맛보기 페이지입니다."
  heading="경영공학과"
  descriptionPrefix={`산업공학과 안에서 공학적 사고와 경영학을 결합한 학과예요. 투자분석, 기술경영, 게임이론까지 다룹니다.`}
  searchPlaceholder="개념 이름으로 검색 (예: 게임이론, MOT, NPV)"
  tracks={TRACKS}
  relatedMajors={RELATED_MAJORS}
/>
