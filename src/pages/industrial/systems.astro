---
import GlossaryLayout from '../../layouts/GlossaryLayout.astro';

const TRACKS = [
  {
    title: '시스템공학과',
    subtitle: 'Systems Engineering',
    careers: ['방위산업체', '항공우주 대형 프로젝트 총괄 팀', '대규모 건설 및 인프라 사업단'],
    courses: [
      {
        name: '시스템공학',
        nameEn: 'Systems Engineering',
        year: '4학년 2학기',
        terms: [
          { ko: '시스템 수명주기', en: 'System Life Cycle', desc: '요구분석-설계-구현-시험-운영-폐기까지 시스템이 태어나서 사라지기까지 거치는 전체 단계를 정의하고, 각 단계에서 무엇을 산출물로 남겨야 다음 단계로 넘어갈 수 있는지 체계적으로 관리하는 접근법. 초기 단계의 오류를 늦게 발견할수록 수정 비용이 기하급수적으로 커지므로, 단계별 검증이 핵심.', example: '전투기 개발 프로젝트가 요구사항 정의부터 실전 배치, 퇴역까지 수십 년의 수명주기를 관리받는 것.' },
          { ko: '요구공학', en: 'Requirements Engineering', desc: '고객·사용자·규제기관 등 다양한 이해관계자가 원하는 바를 인터뷰·워크숍으로 수집하고, 모호함이나 상충을 제거해 명확하고 검증 가능한 문서(요구사항 명세)로 정리하는 과정. 개발이 다 끝난 뒤에야 "이게 아닌데"라는 걸 알게 되는 대형 프로젝트 실패의 상당수가 이 단계의 오류에서 비롯됨.', example: '대형 IT 시스템 구축 실패 사례의 상당수가 초기 요구사항을 잘못 정의한 데서 비롯되는 것.' },
          { ko: '시스템 아키텍처 정의', en: 'System Architecture Definition', desc: '거대한 시스템을 한 번에 설계할 수 없으므로, 기능별로 관리 가능한 하위 시스템들로 나누고 그 하위 시스템들이 서로 정보를 주고받는 인터페이스(입출력 형식, 프로토콜)를 명확히 정의해, 여러 팀이 각자 하위 시스템을 독립적으로 개발해도 나중에 문제없이 통합되게 만드는 작업.', example: '우주선의 추진·전력·통신·생명유지 시스템을 각각 다른 팀이 개발해도 정확히 맞물리게 인터페이스를 미리 정의하는 것.' },
          { ko: '프로젝트 위험 관리', en: 'Project Risk Management', desc: '대규모 프로젝트에서 일정 지연, 예산 초과, 기술적 실패로 이어질 수 있는 위험 요인을 사전에 식별하고, 그 발생 가능성과 영향도를 평가해 우선순위가 높은 위험부터 회피·완화·이전 등 대응 계획을 세우는 관리 기법.', example: '대형 건설 프로젝트에서 자재 수급 지연, 설계 변경 같은 위험을 미리 파악해 일정에 여유를 두는 것.' },
          { ko: '요구사항 추적 및 검증', en: 'Requirements Traceability & Verification', desc: '초기에 정의한 각 요구사항이 설계, 구현, 시험의 어느 단계에서 어떻게 반영·검증되었는지 하나하나 연결해 추적표(traceability matrix)로 관리함으로써, 최종 시스템이 요구사항을 빠짐없이 만족하는지 체계적으로 확인하는 활동.', example: '항공기 인증 심사에서 모든 안전 요구사항이 실제 설계·시험 결과와 정확히 대응되는지 문서로 증명하는 것.' },
        ],
      },
    ],
  },
];

const RELATED_MAJORS = [
  { href: '/industrial', title: '산업공학', subtitle: 'Industrial Engineering' },
  { href: '/industrial/business-analytics', title: '데이터사이언스/BA', subtitle: 'Data Science & Business Analytics' },
  { href: '/industrial/management', title: '경영공학', subtitle: 'Engineering Management' },
  { href: '/industrial/quality', title: '품질경영/신뢰성공학', subtitle: 'Quality & Reliability Engineering' },
  { href: '/industrial/logistics', title: '물류/유통시스템공학', subtitle: 'Logistics Engineering' },
];
---

<GlossaryLayout
  metaTitle="Your Future - 시스템공학 전공 맛보기 | 대치프라임"
  metaDescription="시스템 수명주기, 요구공학, 대형 프로젝트 위험관리까지 시스템공학과 커리큘럼을 재구성한 전공 맛보기 페이지입니다."
  heading="시스템공학과"
  descriptionPrefix={`산업공학과 안에서 복잡한 대형 프로젝트 전체를 설계하고 관리하는 학과예요. 방위산업, 항공우주 같은 초대형 프로젝트에서 핵심 역할을 합니다.`}
  searchPlaceholder="개념 이름으로 검색 (예: 요구공학, 시스템아키텍처, 위험관리)"
  tracks={TRACKS}
  relatedMajors={RELATED_MAJORS}
/>
