---
import GlossaryLayout from '../../layouts/GlossaryLayout.astro';

const TRACKS = [
  {
    title: '물류 / 유통시스템공학과',
    subtitle: 'Logistics & Distribution Systems Engineering',
    careers: ['이커머스 기업(쿠팡·네이버)', '대형 유통·물류사(CJ대한통운·현대글로비스)'],
    courses: [
      {
        name: '물류 및 유통시스템공학',
        nameEn: 'Logistics & Distribution Systems Engineering',
        year: '4학년 1학기',
        terms: [
          { ko: '시설입지선정', en: 'Facility Location', desc: '수요지들의 위치와 물량을 고려해, 물류센터에서 각 수요지까지의 거리(또는 운송비)에 물량을 가중해 합한 총 운송비용이 최소가 되는 위치를 찾는 최적화 문제. 후보지가 많아지면 조합이 폭발적으로 늘어나 정수계획법 같은 최적화 기법으로 풀어냄.', example: '쿠팡이 전국 배송 시간을 단축하기 위해 물류센터(로켓배송 캠프) 위치를 최적화하는 것.' },
          { ko: '차량경로문제', en: 'Vehicle Routing Problem (VRP)', desc: '한 물류센터에서 출발해 여러 고객에게 배송한 뒤 복귀하는 경로를, 각 차량의 적재 용량 제한을 지키면서 전체 이동거리나 시간이 최소가 되도록 짜는 조합 최적화 문제. 고객·차량 수가 늘수록 최적해를 정확히 구하기 어려워 발견적 알고리즘을 실무에서 널리 사용함.', example: '택배기사 한 명이 하루에 배송할 수십 개 주소를 가장 효율적인 순서로 도는 경로를 짜는 것.' },
          { ko: '물류센터 운영 최적화', en: 'Distribution Center Operations Optimization', desc: '상품이 입고되어 저장 위치에 놓이고(입고), 주문에 맞춰 꺼내지고(피킹), 포장·출고되기까지의 내부 동선을 분석해, 작업자나 로봇이 이동하는 거리와 시간을 최소화하도록 저장 위치와 작업 순서를 설계하는 기법.', example: '물류센터에서 자주 나가는 상품을 출고구 가까이에 배치해 피킹 시간을 줄이는 것.' },
          { ko: '재고 통제 시스템', en: 'Inventory Control Systems', desc: '수요가 들쭉날쭉해도 품절이 나지 않으면서 재고비용도 과도하지 않도록, 재고가 특정 수준(재주문점) 이하로 떨어지면 자동으로 주문을 발생시키는 등 재고 수준을 지속적으로 모니터링·관리하는 시스템.', example: '편의점 POS 시스템이 특정 상품 재고가 일정 수준 이하로 떨어지면 자동으로 발주하는 것.' },
          { ko: '화물운송공학', en: 'Freight Transportation Engineering', desc: '화물의 특성(부피, 무게, 긴급도)과 거리에 따라 트럭(유연하지만 비쌈), 철도(대량·저렴하지만 느림), 해상(가장 저렴하지만 매우 느림) 등 서로 다른 강점을 가진 운송 수단을 조합해 총 비용과 시간을 최적화하는 방법을 연구하는 분야.', example: '수출품을 국내에서는 트럭으로, 대양을 건널 때는 해상 운송으로 조합하는 복합운송 계획.' },
          { ko: '네트워크 흐름 최적화', en: 'Network Flow Optimization', desc: '여러 공장·물류센터·소매점이 복잡하게 연결된 공급망 전체를, 각 구간이 흘려보낼 수 있는 용량 제한이 있는 네트워크로 모델링해, 전체 운송비용을 최소화하면서 각 지점의 수요를 만족시키는 최적의 물량 배분을 구하는 최적화 문제. 단순 VRP는 개별 차량 경로를 다루지만, 이 기법은 공급망 전체의 물동량 흐름을 한 번에 최적화하는 더 상위 수준의 문제.', example: '여러 공장에서 여러 물류센터를 거쳐 전국 소매점까지 최적의 물량 배분 경로를 한 번에 계산하는 것.' },
          { ko: '수요예측과 채찍효과', en: 'Demand Forecasting & Bullwhip Effect', desc: '소매점의 실제 수요 변동이 작아도, 그 정보가 도매상-제조사-원자재 공급사로 거슬러 올라가는 각 단계마다 안전재고를 더 얹어 주문하는 과정에서 변동폭이 점점 증폭되는 현상이 채찍효과. 이를 줄이려면 각 단계가 실제 소비자 수요 데이터를 실시간으로 공유해, 앞 단계의 왜곡된 주문량이 아니라 진짜 수요에 맞춰 예측·발주하는 정보 공유 체계가 필요함.', example: '실제 소비자 수요는 조금만 늘었는데 공급망 상류로 갈수록 주문량이 눈덩이처럼 부풀어 오르는 현상.' },
          { ko: '라스트마일 배송', en: 'Last-Mile Delivery', desc: '물류센터에서 대량으로 이동하는 간선운송 구간과 달리, 최종 소비자 문 앞까지 배송하는 마지막 구간(라스트마일)은 건당 배송 물량이 적고 목적지가 흩어져 있어 전체 물류비용에서 가장 비효율적이고 비용 비중이 큰 구간. 이를 개선하려 무인 배송로봇, 드론 배송, 집중형 무인택배함 같은 새로운 배송 방식이 활발히 연구·도입되고 있음.', example: '전체 배송비의 절반 가까이를 차지하는 라스트마일 구간을 무인 로봇으로 자동화하려는 이커머스 업계의 시도.' },
        ],
      },
    ],
  },
];

const RELATED_MAJORS = [
  { href: '/industrial', title: '산업공학', subtitle: 'Industrial Engineering' },
  { href: '/industrial/business-analytics', title: '데이터사이언스/BA', subtitle: 'Data Science & Business Analytics' },
  { href: '/industrial/management', title: '경영공학', subtitle: 'Engineering Management' },
  { href: '/industrial/quality', title: '품질경영/신뢰성공학', subtitle: 'Quality & Reliability Engineering' },
  { href: '/industrial/systems', title: '시스템공학', subtitle: 'Systems Engineering' },
];
---

<GlossaryLayout
  metaTitle="Your Future - 물류/유통시스템공학 전공 맛보기 | 대치프라임"
  metaDescription="물류센터 최적화, 배송 라우팅까지 물류/유통시스템공학과 커리큘럼을 재구성한 전공 맛보기 페이지입니다."
  heading="물류 / 유통시스템공학과"
  descriptionPrefix={`산업공학과 안에서 물건이 가장 빠르고 저렴하게 이동하는 경로를 설계하는 학과예요. 쿠팡·CJ대한통운 같은 물류기업과 직결됩니다.`}
  searchPlaceholder="개념 이름으로 검색 (예: VRP, 물류센터, 재고관리)"
  tracks={TRACKS}
  relatedMajors={RELATED_MAJORS}
/>
