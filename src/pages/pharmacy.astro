          { ko: '약물이상반응 모니터링(ADR)', en: 'Adverse Drug Reaction Monitoring', desc: '약물 복용 후 나타나는 예상치 못한 부작용을 감시하고 보고하는 활동.', example: '새로운 약을 먹고 두드러기가 났을 때 이를 보고하는 시스템.' },
        ],
      },
      {
        name: '약국실무',
        nameEn: 'Pharmacy Practice',
        year: '4학년',
        terms: [
