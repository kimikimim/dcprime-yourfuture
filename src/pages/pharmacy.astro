---
import GlossaryLayout from '../layouts/GlossaryLayout.astro';

const TRACKS = [
  {
    title: '약학기초',
    subtitle: '약물이 몸속에서 어떻게 작용하는지, 그 화학적·생리학적 원리를 다루는 기초 분야',
    careers: ['제약회사 연구원', '약학대학 교수', '신약개발 연구자'],
    courses: [
      {
        name: '약물학',
        nameEn: 'Pharmacology',
        year: '2~3학년',
        terms: [
          { ko: '약물동태학(ADME)', en: 'Pharmacokinetics (ADME)', desc: '약물이 몸속에 흡수(Absorption), 분포(Distribution), 대사(Metabolism), 배설(Excretion)되는 과정을 다루는 학문.', example: '하루 한 번 먹는 약과 하루 세 번 먹는 약의 복용 간격이 다른 이유.' },
