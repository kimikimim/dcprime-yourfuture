    careers: ['아동발달센터 및 언어치료실', '대학병원 재활의학과', '특수학교', '노인요양병원(연하장애 클리닉)'],
    courses: [
      {
        name: '언어병리학',
        nameEn: 'Speech-Language Pathology',
        year: '전공필수',
        terms: [
          { ko: '조음음운장애치료', en: 'Articulation & Phonological Disorders', desc: '특정 발음(ㄹ, ㅅ 등)을 지속적으로 틀리게 발음하는 아동에게, 정확한 혀·입술 위치를 시각적·촉각적 단서로 알려주고 반복 연습시켜 올바른 조음 패턴을 습득시키는 치료.', example: '"사탕"을 "타탕"으로 발음하는 아동이 ㅅ 발음의 정확한 혀 위치를 배워 교정하는 것.' },
          { ko: '언어발달장애치료', en: 'Language Development Disorders', desc: '또래에 비해 어휘·문장구성 능력이 뚜렷이 늦은 아동에게, 놀이 상황 속에서 새로운 단어와 문장구조를 자연스럽게 반복 노출시켜 언어발달을 촉진하는 치료적 개입.', example: '두 단어 문장을 못 만드는 아동이 놀이치료를 통해 "엄마 물"처럼 두 단어를 조합하는 법을 배우는 것.' },
          { ko: '유창성장애(말더듬) 치료', en: 'Fluency Disorders (Stuttering)', desc: '말이 막히거나 음절을 반복하는 말더듬 증상을, 말의 속도를 늦추고 부드럽게 발화를 시작하는 기법(쉬운 시작)이나 호흡 조절 훈련으로 완화시켜 유창한 말하기 패턴을 형성하는 치료.', example: '말을 시작할 때 첫 음절에서 막히는 성인이 부드러운 발성 시작 기법을 연습해 말더듬을 줄이는 것.' },
          { ko: '삼킴장애(연하장애) 치료', en: 'Dysphagia Treatment', desc: '뇌졸중 등으로 음식물을 삼키는 근육 협응이 무너져 기도로 잘못 넘어가는(흡인) 위험이 있는 환자에게, 비디오투시연하검사로 삼킴 과정을 영상으로 분석한 뒤 안전한 자세와 음식물 점도를 조정해 흡인성 폐렴을 예방하는 치료.', example: '삼킴 기능이 약해진 환자에게 물 대신 걸쭉하게 점도를 높인 액체를 제공해 사레들림을 방지하는 것.' },
          { ko: '음성장애치료', en: 'Voice Disorders', desc: '성대 결절이나 무리한 발성 습관으로 목소리가 쉬거나 갈라지는 환자에게, 올바른 호흡법과 발성 기법을 훈련시켜 성대에 무리를 주지 않으면서도 효율적으로 소리를 내는 발성 습관을 형성시키는 치료.', example: '목소리를 많이 쓰는 교사가 성대결절 진단 후 복식호흡 기반 발성법을 훈련받아 목소리를 회복하는 것.' },
        ],
      },
    ],
  },
];

