---
import GlossaryLayout from '../../layouts/GlossaryLayout.astro';

const TRACKS = [
  {
    title: '세라믹공학과',
    subtitle: 'Ceramic Engineering',
    careers: ['반도체 부품사', '세라믹 소재 기업(포스코케미칼·KCC)', '유리 가공 기업'],
    courses: [
      {
        name: '세라믹공학',
        nameEn: 'Ceramic Engineering',
        year: '3학년 2학기',
        terms: [
          { ko: '세라믹의 결합 특성', en: 'Ionic & Covalent Bonding in Ceramics', desc: '금속결합은 전자가 자유롭게 움직여 전위가 쉽게 이동하지만, 세라믹은 특정 방향으로만 강하게 형성되는 이온결합·공유결합으로 이루어져 있어 전위가 이동하려면 이 방향성 있는 강한 결합을 끊어야 함. 그 결과 세라믹은 금속보다 훨씬 단단하고 녹는점이 높지만, 소성변형 없이 부서지기 쉬운 성질을 가짐.', example: '세라믹 칼날이 금속 칼날보다 훨씬 날카로움을 오래 유지하지만 떨어뜨리면 쉽게 깨지는 것.' },
          { ko: '세라믹의 취성', en: 'Brittleness of Ceramics', formula: 'K_{IC} = Y\\sigma\\sqrt{\\pi a}', desc: '전위 이동이 어려운 세라믹은 응력을 소성변형으로 분산시키지 못해, 표면의 미세한 균열(길이 $a$) 끝에 응력이 극도로 집중되면 그대로 균열이 빠르게 전파되어 소성변형 없이 갑자기 깨짐. 파괴인성 $K_{IC}$가 낮을수록 작은 결함에도 쉽게 파괴됨.', example: '유리컵에 생긴 눈에 안 보이는 미세한 흠집이 어느 순간 갑자기 컵을 깨뜨리는 원인.' },
          { ko: '무기재료 열역학', en: 'Thermodynamics of Inorganic Materials', desc: '세라믹·유리 같은 무기재료가 특정 온도·조성에서 어떤 결정상으로 존재하는지, 다른 물질과 반응해 새로운 화합물을 만드는지를 자유에너지 변화로 예측하는 학문. 세라믹은 녹는점이 매우 높아 실험적으로 상평형을 측정하기 어려워, 열역학 계산을 통한 예측이 특히 중요함.', example: '내화벽돌이 고온의 용광로 안에서도 녹거나 반응하지 않고 버틸 조성을 설계하는 것.' },
          { ko: '결정학', en: 'Crystallography', desc: 'X선 회절 등을 이용해 세라믹 결정 내부 원자들의 정확한 배열 위치와 대칭성을 규명하는 학문. 같은 화학식이라도 원자 배열(결정 구조)이 다르면 완전히 다른 물성을 갖기 때문에, 신소재를 개발할 때 결정구조 규명이 물성 이해의 출발점이 됨.', example: '같은 탄소 원자로 이루어졌지만 결정구조가 달라 다이아몬드는 매우 단단하고 흑연은 무른 이유.' },
          { ko: '절연 및 자성 세라믹 소재', en: 'Insulating & Magnetic Ceramic Materials', desc: '자유전자가 없어 전기가 흐르지 않는 절연 세라믹(알루미나 등)과, 철 이온의 자기모멘트가 결정 구조 안에서 정렬되어 자성을 띠는 페라이트 세라믹처럼, 특정 전기·자기적 기능을 갖도록 조성과 결정구조를 설계한 기능성 세라믹.', example: '변압기 코어나 인덕터에 쓰이는 페라이트 자성 세라믹.' },
          { ko: '소결 카이네틱스', en: 'Sintering Kinetics', desc: '분말 입자를 압축한 뒤 가열하면 입자끼리 맞닿은 목(neck) 부분으로 원자가 확산해 서서히 결합하며 치밀해지는데, 이 과정이 초기(입자 사이 목 형성)·중기(기공이 줄어들며 치밀화)·후기(남은 고립 기공 제거) 세 단계를 거치는 속도론으로 기술됨. 온도·시간·입자 크기가 최종 밀도와 결정립 크기를 함께 좌우하므로, 치밀하면서도 결정립이 너무 커지지 않도록(강도 저하 방지) 균형을 맞추는 게 세라믹 공정 설계의 핵심.', example: '세라믹 인공관절이 기공 없이 완전히 치밀하게 소결돼야 인체 하중을 견딜 강도를 확보하는 것.' },
          { ko: '유리의 구조와 점도 거동', en: 'Glass Structure & Viscosity Behavior', desc: '유리는 결정처럼 규칙적인 원자 배열 없이 액체의 무질서한 구조가 그대로 얼어붙은 비정질 고체로, 결정질 재료처럼 명확한 녹는점 대신 온도가 오를수록 점도가 서서히 낮아지며 연화되는 특성을 가짐. 이 점진적인 점도 변화 덕분에 원하는 온도 구간에서 유리를 자유롭게 성형·가공할 수 있음.', example: '유리병 제조 시 정해진 점도 구간에서 유리를 늘리고 불어 원하는 형상을 만드는 것.' },
          { ko: '압전 세라믹과 강유전체', en: 'Piezoelectric Ceramics & Ferroelectrics', desc: 'PZT 같은 강유전체 세라믹은 결정 안에 영구적인 전기쌍극자를 가지고 있어, 외부 전기장으로 이 쌍극자 방향을 정렬시켜 분극시킬 수 있고 이 분극 상태가 전기장을 없애도 유지되는 특성(강유전성)을 보임. 결정 대칭성이 깨져 있어 이 분극 상태가 압전 효과와 결합해, 정밀한 초음파 센서·액추에이터의 핵심 소재로 쓰임.', example: '초음파 진단기가 PZT 세라믹의 압전 효과로 초음파를 발생시키고 반사파를 다시 전기신호로 검출하는 것.' },
        ],
      },
    ],
  },
];

const RELATED_MAJORS = [
  { href: '/materials', title: '신소재공학', subtitle: 'Materials Science & Engineering' },
  { href: '/materials/metal', title: '금속공학', subtitle: 'Metallurgical Engineering' },
  { href: '/materials/electronic', title: '전자재료공학', subtitle: 'Electronic Materials Engineering' },
  { href: '/materials/nano', title: '나노소재공학', subtitle: 'Nanomaterials Engineering' },
  { href: '/materials/bio', title: '생체재료공학', subtitle: 'Biomaterials Engineering' },
  { href: '/materials/composite', title: '복합재료공학', subtitle: 'Composite Materials Engineering' },
];
---

<GlossaryLayout
  metaTitle="Your Future - 세라믹공학 전공 맛보기 | 대치프라임"
  metaDescription="결정학, 무기재료 열역학, 기능성 세라믹까지 세라믹공학과 커리큘럼을 재구성한 전공 맛보기 페이지입니다."
  heading="세라믹공학과"
  descriptionPrefix={`신소재공학부 안에서 도자기, 유리, 반도체 부품용 세라믹까지 무기재료를 다루는 학과예요.`}
  searchPlaceholder="개념 이름으로 검색 (예: 결정학, 취성, 절연세라믹)"
  tracks={TRACKS}
  relatedMajors={RELATED_MAJORS}
/>
