---
import GlossaryLayout from '../../layouts/GlossaryLayout.astro';

const TRACKS = [
  {
    title: '전자재료공학과',
    subtitle: 'Electronic Materials Engineering',
    careers: ['종합 반도체 기업(삼성전자·SK하이닉스)', '디스플레이 제조사(LG디스플레이·삼성디스플레이)', '반도체 소재사'],
    courses: [
      {
        name: '전자재료공학',
        nameEn: 'Electronic Materials Engineering',
        year: '3학년 2학기',
        terms: [
          { ko: '밴드갭', en: 'Band Gap', desc: '전자가 존재할 수 없는 전도띠와 가전자띠 사이의 에너지 간격 $E_g$. $E_g$가 없으면 도체, 좁으면(1~3eV) 반도체, 넓으면 절연체가 되며, 발광소자에서는 전자가 이 간격을 뛰어넘을 때 방출하는 광자의 에너지가 곧 $E_g$ 크기이므로 빛의 색(파장)을 결정함.', example: '적색·녹색·청색 LED가 서로 다른 밴드갭의 화합물반도체로 만들어지는 이유.' },
          { ko: '유전율', en: 'Permittivity (Dielectric Constant)', formula: 'C = \\varepsilon_r \\varepsilon_0 \\frac{A}{d}', desc: '절연체 내부의 전하들이 외부 전기장에 반응해 미세하게 재배열(분극)되는 정도를 나타내는 값. 유전율 $\\varepsilon_r$이 클수록 같은 면적·두께의 커패시터가 더 많은 전하를 저장할 수 있어, 소형화된 고용량 커패시터 재료 개발의 핵심 지표.', example: '스마트폰 기판 위 적층세라믹커패시터(MLCC)를 더 작게 만들면서도 용량을 유지하려는 고유전율 세라믹 개발.' },
          { ko: '압전 효과', en: 'Piezoelectric Effect', desc: '특정 결정(수정, PZT 세라믹 등)은 대칭 중심이 없는 결정구조 때문에 기계적 힘을 받아 격자가 변형되면 양전하·음전하 중심이 어긋나 전압이 발생하고(정압전효과), 반대로 전압을 가하면 그 격자 왜곡으로 결정이 미세하게 변형됨(역압전효과).', example: '라이터를 누르면 압전소자가 순간 고전압을 만들어 불꽃을 튀기는 원리.' },
          { ko: '초전도', en: 'Superconductivity', desc: '특정 임계온도 이하로 냉각하면 전자들이 쿠퍼쌍이라는 짝을 이뤄 격자 진동(저항의 원인)에 산란되지 않고 흐를 수 있게 되어, 전기 저항이 측정 불가능한 수준(사실상 0)까지 완전히 사라지는 양자역학적 현상.', example: 'MRI 장치가 초전도 자석으로 저항 없는 대전류를 흘려 매우 강한 자기장을 만드는 것.' },
          { ko: '반도체 박막공학', en: 'Semiconductor Thin Film Engineering', desc: '스퍼터링, CVD, ALD 등으로 반도체 위에 절연막·금속막·반도체막을 원자층 단위 두께까지 정밀하게 증착·제어하는 기술. 미세화가 진행될수록 막 하나의 두께 오차가 소자 전체 성능에 미치는 영향이 커져 정밀도 요구가 계속 높아짐.', example: '3나노 공정 트랜지스터의 게이트 절연막을 원자 몇 개 두께로 정밀 증착하는 것.' },
          { ko: 'OLED 발광소재 디스플레이', en: 'OLED Emissive Materials for Displays', desc: '전류를 흘리면 전자와 정공이 유기 발광층 안에서 재결합하며 스스로 빛을 내는 유기 발광 소재를 설계·합성하는 기술. 분자 구조를 바꿔 발광 색상과 효율, 수명을 동시에 개선하는 게 핵심 연구 과제.', example: '스마트폰·TV의 OLED 화면에 들어가는 적녹청 발광 유기물 소재 개발.' },
          { ko: '유연소자 재료', en: 'Materials for Flexible Devices', desc: '기존 무기 반도체·금속 배선은 구부리면 쉽게 깨지므로, 신축성 있는 고분자 기판 위에 물결 모양(wavy) 배선 구조나 유연한 나노소재(은나노와이어 등)를 적용해 휘어져도 전기적 특성이 유지되도록 설계된 전자재료.', example: '접히는 스마트폰의 화면과 배선이 접었다 펴도 끊어지지 않는 재료 설계.' },
        ],
      },
    ],
  },
];

const RELATED_MAJORS = [
  { href: '/materials', title: '신소재공학', subtitle: 'Materials Science & Engineering' },
  { href: '/materials/metal', title: '금속공학', subtitle: 'Metallurgical Engineering' },
  { href: '/materials/ceramic', title: '세라믹공학', subtitle: 'Ceramic Engineering' },
  { href: '/materials/nano', title: '나노소재공학', subtitle: 'Nanomaterials Engineering' },
  { href: '/materials/bio', title: '생체재료공학', subtitle: 'Biomaterials Engineering' },
  { href: '/materials/composite', title: '복합재료공학', subtitle: 'Composite Materials Engineering' },
];
