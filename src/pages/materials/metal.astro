---
import GlossaryLayout from '../../layouts/GlossaryLayout.astro';

const TRACKS = [
  {
    title: '금속공학과',
    subtitle: 'Metallurgical Engineering',
    careers: ['철강사(POSCO·현대제철)', '금속 가공 및 가전/자동차 부품 기업'],
    courses: [
      {
        name: '금속공학',
        nameEn: 'Metallurgical Engineering',
        year: '4학년 1학기',
        terms: [
          { ko: '금속 조직학', en: 'Metallography', formula: 'd \\propto t^{1/2}\\ (\\text{결정립 성장})', desc: '시편을 연마·부식시켜 광학·전자현미경으로 관찰하면 금속 내부의 결정립(작은 결정 알갱이) 크기와 상 분포가 드러나는데, 결정립이 작을수록 전위 이동을 가로막는 경계가 많아져 강도가 높아짐(홀-페치 관계). 고온에서 오래 유지될수록 결정립이 서서히 커지므로 열처리 시간·온도가 최종 강도를 좌우함.', example: '용접 부위 근처가 열 영향으로 결정립이 커져 모재보다 약해지는 현상을 조직 관찰로 확인하는 것.' },
          { ko: '합금 설계', en: 'Alloy Design', desc: '기본 금속에 다른 원소를 소량 첨가하면 그 원자가 결정 격자를 미세하게 왜곡시켜 전위 이동을 방해(고용강화)하거나, 별도의 미세한 석출물을 만들어 전위를 가로막는(석출강화) 방식으로 강도를 높이는 원리를 이용해, 원하는 강도·내식성·가공성 조합을 얻도록 첨가 원소와 비율을 설계하는 기술.', example: '알루미늄에 구리를 소량 첨가해 항공기용 초경량 고강도 합금(두랄루민)을 만드는 것.' },
          { ko: '열처리 및 표면공학', en: 'Heat Treatment & Surface Engineering', desc: '담금질로 원자 확산을 억제해 단단하지만 취성이 큰 조직을 만들고 뜨임으로 인성을 보완하는 내부 조직 제어와, 질화·침탄처럼 표면층에만 별도의 원소를 확산시켜 내부는 연하고 표면만 단단하게 만드는 표면공학을 함께 다루는 영역.', example: '기어 이빨은 표면만 단단하게 침탄 처리해 마모는 견디면서 충격에는 부러지지 않게 만드는 것.' },
          { ko: '철강 및 비철금속 제조공정', en: 'Ferrous & Non-Ferrous Metal Manufacturing', desc: '철광석을 고로에서 코크스와 함께 태워 산소를 제거(환원)해 철을 얻고 전로에서 불순물을 산화시켜 제거하는 제철·제강 공정과, 알루미늄·구리처럼 철이 아닌 금속을 전기분해나 용융 정련으로 순도 높게 뽑아내고 압연·압출로 가공하는 비철금속 공정.', example: '철광석에서 시작해 자동차 강판까지 만들어지는 제철소의 일관 생산 공정.' },
          { ko: '석출강화 카이네틱스', en: 'Precipitation Strengthening Kinetics', desc: '합금을 고온에서 급랭해 첨가원소를 강제로 과포화시킨 뒤, 다시 적당한 온도로 재가열(시효처리)하면 과포화된 원소가 미세한 석출물 입자로 서서히 빠져나오며 결정 격자를 국부적으로 왜곡시켜 전위 이동을 가로막음. 시효 시간이 짧으면 석출물이 너무 작아 효과가 적고, 너무 길면 석출물이 뭉쳐 커지면서 오히려 강화 효과가 줄어드는(과시효) 정점이 있어, 최대 강도를 내는 시효 시간·온도를 정밀하게 맞추는 게 핵심.', example: '항공기용 알루미늄 합금이 열처리 후 실온에서 며칠에 걸쳐 서서히 강도가 올라가는 자연시효 현상.' },
        ],
      },
    ],
  },
];

const RELATED_MAJORS = [
  { href: '/materials', title: '신소재공학', subtitle: 'Materials Science & Engineering' },
  { href: '/materials/ceramic', title: '세라믹공학', subtitle: 'Ceramic Engineering' },
  { href: '/materials/electronic', title: '전자재료공학', subtitle: 'Electronic Materials Engineering' },
  { href: '/materials/nano', title: '나노소재공학', subtitle: 'Nanomaterials Engineering' },
  { href: '/materials/bio', title: '생체재료공학', subtitle: 'Biomaterials Engineering' },
  { href: '/materials/composite', title: '복합재료공학', subtitle: 'Composite Materials Engineering' },
];
---

<GlossaryLayout
  metaTitle="Your Future - 금속공학 전공 맛보기 | 대치프라임"
  metaDescription="금속 조직학, 합금 설계, 제철 공정까지 금속공학과 커리큘럼을 재구성한 전공 맛보기 페이지입니다."
  heading="금속공학과"
  descriptionPrefix={`신소재공학부 안에서 철강과 비철금속을 다루는 가장 전통적인 학과예요. 조직 관찰부터 합금 설계, 제조 공정까지 배웁니다.`}
  searchPlaceholder="개념 이름으로 검색 (예: 합금설계, 열처리, 제강)"
  tracks={TRACKS}
  relatedMajors={RELATED_MAJORS}
/>
