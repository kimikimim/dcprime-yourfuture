---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

const SCIENCE_CONTENTS = [
  {
    href: '/math',
    title: '수학',
    subtitle: 'Mathematics',
    desc: '해석학, 대수학, 위상수학 등 핵심 과목 맛보기.',
  },
  {
    href: '/physics',
    title: '물리학',
    subtitle: 'Physics',
    desc: '고전역학, 전자기학, 현대물리학의 핵심 과목 맛보기.',
  },
  {
    href: '/chemistry',
    title: '화학',
    subtitle: 'Chemistry',
    desc: '물리화학, 유기화학, 분석/무기화학의 핵심 과목 맛보기.',
  },
  {
    href: '/statistics',
    title: '통계학',
    subtitle: 'Statistics',
    desc: '확률론, 통계적 추론, 데이터과학의 핵심 과목 맛보기.',
  },
];

const ENGINEERING_CONTENTS = [
  {
    href: '/cs',
    title: '컴퓨터공학',
    subtitle: 'Computer Science and Engineering',
    desc: '컴퓨터공학, 소프트웨어, 정보보안, 인공지능, 데이터사이언스까지 5개 세부 학과 맛보기.',
  },
  {
    href: '/ee',
    title: '전기전자공학',
    subtitle: 'Electrical & Electronic Engineering',
    desc: '회로, 전자기학, 신호·통신·제어의 핵심 과목 맛보기.',
  },
  {
    href: '/semiconductor',
    title: '반도체공학',
    subtitle: 'Semiconductor Engineering',
    desc: '소자물리, 공정, 집적회로 설계의 핵심 과목 맛보기.',
  },
  {
    href: '/mechanical',
    title: '기계공학',
    subtitle: 'Mechanical Engineering',
    desc: '역학, 열역학, 유체역학, 설계의 핵심 과목 맛보기.',
  },
  {
    href: '/chemical',
    title: '화학공학',
    subtitle: 'Chemical Engineering',
    desc: '열역학, 반응공학, 이동현상, 공정설계의 핵심 과목 맛보기.',
  },
  {
    href: '/materials',
    title: '신소재공학',
    subtitle: 'Materials Science & Engineering',
    desc: '결정구조, 상변태, 물성, 공정의 핵심 과목 맛보기.',
  },
  {
    href: '/industrial',
    title: '산업공학',
    subtitle: 'Industrial Engineering',
    desc: '최적화, 통계, 생산·품질 시스템의 핵심 과목 맛보기.',
  },
  {
    href: '/architecture',
    title: '건축토목공학부',
    subtitle: 'Architecture & Civil Engineering',
    desc: '건축학, 건축공학, 토목공학 3대 축의 핵심 과목 맛보기.',
  },
  {
    href: '/aerospace',
    title: '항공우주공학과',
    subtitle: 'Aerospace Engineering',
    desc: '항공기 구조, 추진기관, 유도제어, 위성시스템 맛보기.',
  },
];

const MEDICAL_CONTENTS = [
  {
    href: '/medicine',
    title: '의학과',
    subtitle: 'Medicine',
    desc: '내과·외과·진단지원·특수진료계열 대표 진료과 맛보기.',
  },
  {
    href: '/pharmacy',
    title: '약학과',
    subtitle: 'Pharmacy',
    desc: '약물학부터 신약개발, 임상 조제까지 핵심 과목 맛보기.',
  },
  {
    href: '/nursing',
    title: '간호학과',
    subtitle: 'Nursing',
    desc: '임상간호, 지역사회·정신간호, 간호관리 핵심 과목 맛보기.',
  },
];
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon-circle.png" />
    <meta name="generator" content={Astro.generator} />
    <title>Your Future | 대치프라임</title>
    <meta name="description" content="대학 진학 전, 전공과 학문의 세계를 가볍게 미리 만나보는 대치프라임의 콘텐츠 모음입니다." />
    <meta name="robots" content="index, follow" />
  </head>
  <body class="bg-gray-50 font-sans">

    <SiteHeader backHref="https://dcprime.co.kr" backLabel="dcprime.co.kr 로 돌아가기 →" />

    <div class="min-h-screen">
      <div class="border-b border-gray-200 bg-white">
        <div class="container mx-auto px-4 py-10 sm:py-14 text-center">
          <p class="text-sm text-brand font-semibold mb-2">Your Future</p>
          <h1 class="text-xl sm:text-2xl md:text-3xl font-bold text-gray-900">대학 이후를 가볍게 미리 만나보세요</h1>
          <p class="text-sm text-gray-500 mt-3 leading-relaxed max-w-xl mx-auto">
            자네들의 미래를 맛보거라.
          </p>
        </div>
      </div>

      <div class="container mx-auto px-4 py-8 sm:py-10 max-w-5xl">
        <div class="mb-4">
          <h2 class="text-base sm:text-lg font-bold text-gray-900">자연과학</h2>
          <p class="text-xs text-gray-400">Natural Sciences</p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-12">
          {SCIENCE_CONTENTS.map((c) => (
            <a
              href={c.href}
              class="block bg-white rounded-xl border border-gray-100 p-6 shadow-sm hover:border-brand hover:shadow-md transition-all"
            >
              <p class="text-lg font-bold text-gray-900">{c.title}</p>
              <p class="text-xs text-gray-400 mb-3">{c.subtitle}</p>
              <p class="text-sm text-gray-600 leading-relaxed">{c.desc}</p>
              <p class="text-sm text-brand font-semibold mt-4">자세히 보기 →</p>
            </a>
          ))}
        </div>

        <div class="mb-4">
          <h2 class="text-base sm:text-lg font-bold text-gray-900">공과대학</h2>
          <p class="text-xs text-gray-400">Engineering</p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {ENGINEERING_CONTENTS.map((c) => (
            c.comingSoon ? (
              <div class="block bg-white rounded-xl border border-gray-100 p-6 shadow-sm opacity-60">
                <p class="text-lg font-bold text-gray-900">{c.title}</p>
                <p class="text-xs text-gray-400 mb-3">{c.subtitle}</p>
                <p class="text-sm text-gray-600 leading-relaxed">{c.desc}</p>
                <p class="text-sm text-gray-400 font-semibold mt-4">준비 중</p>
              </div>
            ) : (
              <a
                href={c.href}
                class="block bg-white rounded-xl border border-gray-100 p-6 shadow-sm hover:border-brand hover:shadow-md transition-all"
              >
                <p class="text-lg font-bold text-gray-900">{c.title}</p>
                <p class="text-xs text-gray-400 mb-3">{c.subtitle}</p>
                <p class="text-sm text-gray-600 leading-relaxed">{c.desc}</p>
                <p class="text-sm text-brand font-semibold mt-4">자세히 보기 →</p>
              </a>
            )
          ))}
        </div>

        <div class="mb-4 mt-12">
          <h2 class="text-base sm:text-lg font-bold text-gray-900">의과대학</h2>
          <p class="text-xs text-gray-400">Medicine</p>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {MEDICAL_CONTENTS.map((c) => (
            <a
              href={c.href}
              class="block bg-white rounded-xl border border-gray-100 p-6 shadow-sm hover:border-brand hover:shadow-md transition-all"
            >
              <p class="text-lg font-bold text-gray-900">{c.title}</p>
              <p class="text-xs text-gray-400 mb-3">{c.subtitle}</p>
              <p class="text-sm text-gray-600 leading-relaxed">{c.desc}</p>
              <p class="text-sm text-brand font-semibold mt-4">자세히 보기 →</p>
            </a>
          ))}
        </div>
      </div>
    </div>

    <SiteFooter />
  </body>
</html>
