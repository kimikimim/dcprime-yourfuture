---
import '../styles/global.css';

const SCIENCE_CONTENTS = [
  {
    href: '/math',
    title: '대학수학 개념 사전',
    subtitle: 'Math Glossary',
    desc: '전공을 정하기 전, 대학 수학이 어떤 걸 다루는지 가볍게 훑어보는 페이지입니다.',
  },
];

const ENGINEERING_CONTENTS = [
  {
    href: '/cs',
    title: '컴퓨터공학',
    subtitle: 'Computer Science',
    desc: '알고리즘, 시스템, 이론전산학의 핵심 개념 맛보기.',
  },
  {
    href: '/ee',
    title: '전자공학',
    subtitle: 'Electrical Engineering',
    desc: '회로, 전자기학, 신호처리, 제어의 핵심 개념 맛보기.',
  },
  {
    href: '/semiconductor',
    title: '반도체공학',
    subtitle: 'Semiconductor Engineering',
    desc: '소자물리, 공정, 집적회로 설계의 핵심 개념 맛보기.',
  },
  {
    href: '/mechanical',
    title: '기계공학',
    subtitle: 'Mechanical Engineering',
    desc: '역학, 열역학, 유체역학, 설계의 핵심 개념 맛보기.',
  },
  {
    href: '/chemical',
    title: '화학공학',
    subtitle: 'Chemical Engineering',
    desc: '열역학, 반응공학, 이동현상, 공정설계의 핵심 개념 맛보기.',
  },
  {
    href: '/materials',
    title: '신소재공학',
    subtitle: 'Materials Science & Engineering',
    desc: '결정구조, 상변태, 물성, 공정의 핵심 개념 맛보기.',
  },
  {
    href: '/industrial',
    title: '산업공학',
    subtitle: 'Industrial Engineering',
    desc: '최적화, 통계, 생산·품질 시스템의 핵심 개념 맛보기.',
  },
  {
    href: '/architecture',
    title: '건축공학',
    subtitle: 'Architectural Engineering',
    desc: '구조, 시공, 건축계획의 핵심 개념 맛보기.',
    comingSoon: true,
  },
  {
    href: '/aerospace',
    title: '항공우주공학',
    subtitle: 'Aerospace Engineering',
    desc: '공기역학, 추진, 궤도역학의 핵심 개념 맛보기.',
    comingSoon: true,
  },
];
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon-circle.png" />
    <meta name="generator" content={Astro.generator} />
    <title>Your Future | 대치프라임</title>
    <meta name="description" content="대학 진학 전, 전공과 학문의 세계를 가볍게 미리 만나보는 대치프라임의 콘텐츠 모음입니다." />
    <meta name="robots" content="index, follow" />
  </head>
  <body class="bg-gray-50 font-sans">

    <header class="border-b border-gray-200 bg-white">
      <div class="container mx-auto px-4 py-4 flex items-center justify-between">
        <a href="https://dcprime.co.kr" class="flex items-center gap-2">
          <img src="/favicon-circle.png" alt="대치프라임" class="h-9 w-9 rounded-full object-cover" />
          <span class="text-sm font-bold text-gray-900">대치프라임</span>
        </a>
        <a href="https://dcprime.co.kr" class="text-xs text-gray-400 hover:text-brand transition-colors">dcprime.co.kr 로 돌아가기 →</a>
      </div>
    </header>

    <div class="min-h-screen">
      <div class="border-b border-gray-200 bg-white">
        <div class="container mx-auto px-4 py-14 text-center">
          <p class="text-sm text-brand font-semibold mb-2">Your Future</p>
          <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">대학 이후를 가볍게 미리 만나보세요</h1>
          <p class="text-sm text-gray-500 mt-3 leading-relaxed max-w-xl mx-auto">
            전공을 정하기 전, 대학에서 만나게 될 학문의 세계를 가볍게 훑어보는 대치프라임의 콘텐츠 모음입니다.
          </p>
        </div>
      </div>

      <div class="container mx-auto px-4 py-10 max-w-4xl">
        <div class="mb-4">
          <h2 class="text-lg font-bold text-gray-900">자연과학</h2>
          <p class="text-xs text-gray-400">Natural Sciences</p>
        </div>
        <div class="grid sm:grid-cols-2 gap-4 mb-12">
          {SCIENCE_CONTENTS.map((c) => (
            <a
              href={c.href}
              class="block bg-white rounded-xl border border-gray-100 p-6 shadow-sm hover:border-brand hover:shadow-md transition-all"
            >
              <p class="text-lg font-bold text-gray-900">{c.title}</p>
              <p class="text-xs text-gray-400 mb-3">{c.subtitle}</p>
              <p class="text-sm text-gray-600 leading-relaxed">{c.desc}</p>
              <p class="text-sm text-brand font-semibold mt-4">자세히 보기 →</p>
            </a>
          ))}
        </div>

        <div class="mb-4">
          <h2 class="text-lg font-bold text-gray-900">공과대학</h2>
          <p class="text-xs text-gray-400">Engineering</p>
        </div>
        <div class="grid sm:grid-cols-2 gap-4">
          {ENGINEERING_CONTENTS.map((c) => (
            c.comingSoon ? (
              <div class="block bg-white rounded-xl border border-gray-100 p-6 shadow-sm opacity-60">
                <p class="text-lg font-bold text-gray-900">{c.title}</p>
                <p class="text-xs text-gray-400 mb-3">{c.subtitle}</p>
                <p class="text-sm text-gray-600 leading-relaxed">{c.desc}</p>
                <p class="text-sm text-gray-400 font-semibold mt-4">준비 중</p>
              </div>
            ) : (
              <a
                href={c.href}
                class="block bg-white rounded-xl border border-gray-100 p-6 shadow-sm hover:border-brand hover:shadow-md transition-all"
              >
                <p class="text-lg font-bold text-gray-900">{c.title}</p>
                <p class="text-xs text-gray-400 mb-3">{c.subtitle}</p>
                <p class="text-sm text-gray-600 leading-relaxed">{c.desc}</p>
                <p class="text-sm text-brand font-semibold mt-4">자세히 보기 →</p>
              </a>
            )
          ))}
        </div>
      </div>
    </div>

    <footer class="border-t border-gray-200 bg-white py-8">
      <div class="container mx-auto px-4 text-center text-xs text-gray-400">
        <p>문제 있으면 장곡관 튜터에게.</p>
        <a href="https://github.com/kimikimim" class="text-brand hover:underline" target="_blank" rel="noopener noreferrer">github.com/kimikimim</a>
      </div>
    </footer>
  </body>
</html>
