---
import GlossaryLayout from '../../layouts/GlossaryLayout.astro';

const TRACKS = [
  {
    title: '생명화학공학 / 바이오화학공학과',
    subtitle: 'Biochemical Engineering',
    careers: ['바이오/제약 기업(삼성바이오로직스·셀트리온·SK바이오사이언스)', '식품 및 화장품 기업'],
    courses: [
      {
        name: '생명화학공학',
        nameEn: 'Biochemical Engineering',
        year: '4학년 1학기',
        terms: [
          { ko: '생물반응기 설계', en: 'Bioreactor Design', desc: '미생물이나 동물세포가 생존·증식하기 좋은 온도·pH·용존산소 농도를 정밀하게 유지하면서 대량으로 배양해 원하는 물질(항체, 대사산물 등)을 생산하는 반응기를 설계하는 기술. 세포는 화학물질과 달리 산소 공급이 과하거나 부족하면 죽어버리므로, 교반 강도까지 세포에 손상을 주지 않는 범위로 조절해야 함.', example: '항체 치료제를 생산하는 동물세포를 수천 리터 규모 탱크에서 배양하는 바이오 의약품 생산시설.' },
          { ko: '바이오의약품 정제공정', en: 'Biopharmaceutical Purification', desc: '세포 배양액 안에는 목표 단백질 외에도 세포 파편, 다른 단백질, 바이러스 등 불순물이 섞여 있어, 크로마토그래피 등으로 크기·전하·결합 특이성 차이를 이용해 단계적으로 걸러내 순도 99.9% 이상까지 끌어올리는 다단계 정제 공정. 일반 화학 공정보다 훨씬 까다로운 순도 기준을 요구함.', example: '항체 치료제가 환자에게 투여되기 전 거치는 여러 단계의 정제·검증 공정.' },
          { ko: '발효공정', en: 'Fermentation Process', desc: '효모·세균 같은 미생물이 산소가 있거나 없는 환경에서 영양분을 분해하며 부산물로 알코올, 유기산, 항생제 등 원하는 물질을 만들어내는 대사 작용을 대량 생산에 활용하는 공정. 미생물 균주 자체를 유전적으로 개량해 생산성을 높이는 것도 이 분야의 핵심 과제.', example: '맥주 양조에서 효모가 당을 알코올과 이산화탄소로 분해하는 발효 과정을 대규모 산업으로 확장한 것.' },
          { ko: '효소공학', en: 'Enzyme Engineering (Michaelis-Menten Kinetics)', formula: 'v = \\frac{V_{max}[S]}{K_m+[S]}', desc: '효소가 기질과 결합해 반응을 촉매하는 속도 $v$가 기질 농도 $[S]$가 낮을 때는 거의 비례해서 늘다가, 효소가 포화되는 높은 농도에서는 최대속도 $V_{max}$로 수렴하는 관계를 기술하는 반응속도론. $K_m$은 효소가 기질과 얼마나 강하게 결합하는지를 나타내며, 이 값이 작을수록 낮은 기질 농도에서도 효소가 효율적으로 작동함.', example: '세제에 들어가는 단백질분해효소가 낮은 온도에서도 얼룩을 잘 분해하도록 효소를 개량하는 것.' },
          { ko: '대사공학', en: 'Metabolic Engineering', desc: '미생물이 원래 가진 수백 개의 대사 반응 경로 중, 원하는 물질을 만드는 경로의 효소는 유전자 조작으로 더 많이 발현시키고 경쟁하는 부반응 경로는 억제해, 미생물이 자기 생존보다 목표 물질 생산에 대사 자원을 더 많이 쓰도록 균주 자체를 재설계하는 기술. 대사 흐름을 전체 네트워크 수준에서 시뮬레이션(flux balance analysis)해 어느 유전자를 조작해야 생산성이 극대화되는지 미리 예측하기도 함.', example: '대장균이나 효모가 원래 만들지 않던 인슐린·바이오연료 같은 물질을 대량 생산하도록 유전적으로 재설계하는 것.' },
        ],
      },
    ],
  },
];

const RELATED_MAJORS = [
  { href: '/chemical', title: '화학공학', subtitle: 'Chemical Engineering' },
  { href: '/chemical/polymer', title: '고분자공학', subtitle: 'Polymer Engineering' },
  { href: '/chemical/energy', title: '에너지화학공학', subtitle: 'Energy Chemical Engineering' },
  { href: '/chemical/environmental', title: '환경화학공학', subtitle: 'Environmental Chemical Engineering' },
];
---

<GlossaryLayout
  metaTitle="Your Future - 생명화학공학 전공 맛보기 | 대치프라임"
  metaDescription="바이오의약품, 발효, 효소공학까지 생명화학공학과 커리큘럼을 재구성한 전공 맛보기 페이지입니다."
  heading="생명화학공학 / 바이오화학공학과"
  descriptionPrefix={`화학공학부 안에서 미생물, 세포, 효소를 이용해 의약품과 유용물질을 생산하는 학과예요. 바이오 산업과 가장 맞닿아 있습니다.`}
  searchPlaceholder="개념 이름으로 검색 (예: 생물반응기, 발효, 효소)"
  tracks={TRACKS}
  relatedMajors={RELATED_MAJORS}
/>
