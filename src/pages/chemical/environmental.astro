---
import GlossaryLayout from '../../layouts/GlossaryLayout.astro';

const TRACKS = [
  {
    title: '환경화학공학과',
    subtitle: 'Environmental Chemical Engineering',
    careers: ['기업 내 ESG/환경안전 부서', '환경 전문 엔지니어링 기업', '한국환경공단 등 공공기관'],
    courses: [
      {
        name: '환경화학공학',
        nameEn: 'Environmental Chemical Engineering',
        year: '3학년 2학기',
        terms: [
          { ko: '탄소포집·활용·저장', en: 'Carbon Capture, Utilization & Storage (CCUS)', desc: '배출가스 중 이산화탄소를 아민 용액 등에 화학적으로 흡수시켜 선택적으로 포집한 뒤, 포집한 CO2를 화학원료로 재활용하거나 압축해 지하 깊은 지층(고갈된 유가스전 등)에 영구 저장함으로써 대기 중 탄소 배출을 줄이는 기술.', example: '제철소·화력발전소 굴뚝에서 나오는 CO2를 포집해 땅속에 묻는 대규모 탄소 저감 프로젝트.' },
          { ko: '폐수 및 폐기물 화학적 처리', en: 'Chemical Treatment of Wastewater & Waste', desc: '침전·여과 같은 물리적 처리, 응집제·산화제를 이용한 화학적 처리, 미생물이 오염물질을 분해하는 생물학적 처리를 단계적으로 조합해, 폐수·폐기물 속 오염물질 농도를 법적 배출 기준 이하로 낮추는 공정.', example: '공장 폐수가 하천에 방류되기 전 여러 단계의 정화 공정을 거치는 처리시설.' },
          { ko: '대기오염 방지공정', en: 'Air Pollution Control Process', desc: '배출가스 중 황산화물·질소산화물을 알칼리 용액에 흡수시켜 중화하거나(탈황·탈질), 촉매 표면에서 무해한 질소·물로 화학 변환시키는(선택적 촉매환원, SCR) 등 오염물질의 화학적 성질에 맞춰 제거 방식을 설계하는 공정 기술.', example: '화력발전소 굴뚝에 설치된 탈황·탈질 설비가 배출가스를 정화하는 것.' },
          { ko: '친환경 대체 공정', en: 'Eco-Friendly Alternative Processes', desc: '유해한 유기용매 대신 물이나 이산화탄소 초임계유체를 쓰거나, 반응 단계를 줄여 부산물과 에너지 소비를 함께 낮추는 방향으로 기존 화학 공정 전체를 원자단위 효율까지 고려해 재설계하는 그린케미스트리 접근법.', example: '드라이클리닝에서 유해 용제 대신 초임계 이산화탄소를 세정 용매로 쓰는 친환경 공정.' },
          { ko: '반응동역학 기반 오염물질 처리 모델링', en: 'Kinetic Modeling of Pollutant Degradation', desc: '오염물질이 산화제나 미생물에 의해 분해되는 속도가 시간에 따라 어떻게 변하는지(1차·2차 반응속도론)를 실험 데이터로 규명해, 원하는 처리 수준까지 도달하는 데 필요한 반응조 크기와 체류시간을 정량적으로 설계하는 기법. 감(感)으로 설비를 과설계하는 대신, 실제 반응속도 데이터에 기반해 최소 비용으로 배출 기준을 만족시키는 설비를 설계할 수 있음.', example: '폐수처리장의 반응조 크기를 오염물질 분해 속도 실험 데이터에 근거해 정확히 설계하는 것(과대 설계로 인한 비용 낭비 방지).' },
          { ko: '고급산화공정(AOP)', en: 'Advanced Oxidation Process (AOP)', desc: '일반 산화제로는 잘 분해되지 않는 난분해성 오염물질(의약품 잔류물, 산업 특수화학물질 등)을 처리하기 위해, 오존·과산화수소에 자외선이나 촉매를 결합시켜 반응성이 극도로 높은 하이드록시라디칼을 다량 생성해 오염물질을 거의 무차별적으로 산화·분해시키는 처리 기법. 기존 생물학적 처리로는 안 되는 물질까지 처리할 수 있지만 에너지·약품 비용이 높음.', example: '일반 하수처리로는 분해되지 않는 의약품 성분을 완전히 분해하기 위해 오존+자외선 공정을 추가하는 것.' },
          { ko: '생명주기평가(LCA)', en: 'Life Cycle Assessment (LCA)', desc: '어떤 제품이나 공정이 환경에 미치는 영향을, 원료 채취부터 생산, 사용, 폐기까지 전체 생애주기에 걸쳐 정량적으로 평가하는 방법론. 특정 한 단계만 친환경적으로 보여도 전체 생애주기로 보면 오히려 환경 부담이 클 수 있어, 부분적 인상이 아니라 전체를 놓고 진짜 친환경적인 대안을 객관적으로 비교하는 데 필수적.', example: '플라스틱 빨대와 종이 빨대 중 어느 쪽이 생산부터 폐기까지 전체 환경영향이 더 적은지 객관적으로 비교하는 것.' },
        ],
      },
    ],
  },
];

const RELATED_MAJORS = [
  { href: '/chemical', title: '화학공학', subtitle: 'Chemical Engineering' },
