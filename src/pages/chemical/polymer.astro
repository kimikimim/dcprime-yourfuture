---
import GlossaryLayout from '../../layouts/GlossaryLayout.astro';

const TRACKS = [
  {
    title: '고분자공학과',
    subtitle: 'Polymer Engineering',
    careers: ['석유화학 및 소재 기업(금호석유화학·한화솔루션·효성첨단소재)', '타이어 제조사'],
    courses: [
      {
        name: '고분자공학',
        nameEn: 'Polymer Engineering',
        year: '3학년 1학기',
        terms: [
          { ko: '고분자 합성 기술', en: 'Polymerization (Addition/Condensation)', desc: '단위체(모노머) 분자의 이중결합이 연쇄적으로 열리며 라디칼이나 이온을 매개로 서로 계속 연결되는 부가중합(폴리에틸렌 등)과, 두 종류의 작용기를 가진 단위체들이 결합할 때마다 물 같은 작은 분자를 하나씩 방출하며 사슬을 늘려가는 축합중합(나일론, 폴리에스터 등)으로 나뉘는 고분자 생성 반응.', example: '페트병(축합중합의 폴리에스터)과 비닐봉지(부가중합의 폴리에틸렌)가 서로 다른 방식으로 만들어지는 것.' },
          { ko: '고분자 물성', en: 'Polymer Properties (Crystallinity/Tg)', desc: '고분자 사슬이 규칙적으로 접혀 정렬된 정도(결정화도)가 높을수록 단단하고 불투명해지며, 사슬의 무작위 열운동이 냉각으로 얼어붙어 유리처럼 딱딱해지는 온도인 유리전이온도($T_g$)를 경계로 고분자는 고무처럼 유연한 상태와 유리처럼 딱딱한 상태를 오감. 이 두 값으로 고분자의 강도·유연성·내열성을 예측함.', example: '고무줄이 냉동실에 넣으면 유리전이온도 아래로 내려가 딱딱하게 부서지는 현상.' },
          { ko: '플라스틱 및 고무 성형가공법', en: 'Plastic & Rubber Molding/Processing', desc: '고분자를 녹는점 근처까지 가열해 유동성을 갖게 만든 뒤, 금형에 고압으로 밀어넣어 굳히는 사출성형이나 다이를 통과시켜 일정한 단면 형상을 연속적으로 뽑아내는 압출 등으로 원하는 제품 형태를 만드는 가공 기술.', example: '스마트폰 케이스나 자동차 범퍼가 사출성형기로 대량 생산되는 과정.' },
          { ko: '고기능성 섬유', en: 'High-Performance Fibers', desc: '고분자 사슬을 방사(가는 실 형태로 뽑아냄) 후 강하게 잡아당겨(연신) 사슬을 섬유 방향으로 최대한 나란히 정렬시킴으로써, 일반 섬유보다 훨씬 높은 인장강도나 내열성을 갖게 만든 특수 섬유 소재.', example: '방탄조끼에 쓰이는 아라미드 섬유(케블라), 항공기 동체에 쓰이는 탄소섬유.' },
          { ko: '복합재료 유변학', en: 'Rheology of Composite Materials', formula: '\\tau = \\eta \\dot{\\gamma}', desc: '고분자 용융물처럼 전단속도 $\\dot{\\gamma}$가 커질수록 점도 $\\eta$가 낮아지는 비뉴턴 유체의 흐름·변형 특성을 연구하는 학문. 사출성형 시 금형 구석구석까지 재료가 얼마나 잘 채워지는지, 압출 시 어떤 압력이 필요한지를 예측하는 데 필수적.', example: '케첩을 흔들면 더 잘 나오는 것처럼, 고분자 용융물도 전단력을 받으면 점도가 낮아지는 성질을 이용한 성형 공정 설계.' },
          { ko: '고분자 사슬의 통계역학', en: 'Statistical Mechanics of Polymer Chains', formula: '\\langle R^2 \\rangle = nl^2\\ (\\text{자유회전사슬})', desc: '고분자 한 가닥은 수천~수만 개의 단위체가 이어진 사슬이 무작위로 꼬이고 뒤엉킨 형태를 띠는데, 이 사슬의 평균적인 크기(말단간거리 제곱의 평균)를 단위체 개수 $n$과 결합 길이 $l$로 통계적으로 기술하는 이론. 실제 고무의 탄성이나 고분자 용액의 점도 같은 거시적 물성이 사슬 하나하나의 이런 통계적 형태로부터 설명됨.', example: '고무줄이 늘어났다 놓으면 원래대로 돌아오는 탄성이 사슬이 다시 무작위 형태로 되돌아가려는 통계적 경향에서 비롯되는 것.' },
          { ko: '분자량 분포와 다분산도', en: 'Molecular Weight Distribution & Polydispersity', formula: 'PDI = M_w/M_n', desc: '고분자 합성 반응은 사슬마다 정확히 같은 길이로 자라지 않아, 하나의 고분자 시료 안에도 짧은 사슬부터 긴 사슬까지 분자량이 분포함. 개수 기준 평균 $M_n$과 무게 기준 평균 $M_w$의 비율인 다분산도(PDI)가 1에 가까울수록 사슬 길이가 균일하며, 이 분포의 폭이 고분자의 강도·가공성·용융 특성에 큰 영향을 줌.', example: '같은 폴리에틸렌이라도 다분산도에 따라 필름용, 파이프용 등 서로 다른 용도에 맞게 설계되는 것.' },
          { ko: '고분자 블렌드와 상용성', en: 'Polymer Blends & Compatibility', desc: '두 가지 이상의 고분자를 섞어 각각의 장점을 조합하려 할 때, 대부분의 고분자 쌍은 분자 수준에서 잘 섞이지 않고 미세하게 분리된 상을 이루는데, 이 상분리 정도(상용성)가 블렌드의 최종 물성을 좌우함. 상용화제(두 고분자 모두와 잘 결합하는 첨가제)를 넣어 계면을 안정화시키면 서로 다른 고분자의 장점을 동시에 갖는 신소재를 만들 수 있음.', example: '충격에 강한 고무 성분과 강도가 높은 플라스틱을 블렌드해 두 장점을 모두 가진 자동차 범퍼 소재를 만드는 것.' },
        ],
      },
    ],
  },
];

const RELATED_MAJORS = [
  { href: '/chemical', title: '화학공학', subtitle: 'Chemical Engineering' },
  { href: '/chemical/energy', title: '에너지화학공학', subtitle: 'Energy Chemical Engineering' },
  { href: '/chemical/bio', title: '생명화학공학', subtitle: 'Biochemical Engineering' },
  { href: '/chemical/environmental', title: '환경화학공학', subtitle: 'Environmental Chemical Engineering' },
];
---

<GlossaryLayout
  metaTitle="Your Future - 고분자공학 전공 맛보기 | 대치프라임"
  metaDescription="고분자 합성부터 성형가공, 복합재료까지 고분자공학과 커리큘럼을 재구성한 전공 맛보기 페이지입니다."
  heading="고분자공학과"
  descriptionPrefix={`화학공학부 안에서 플라스틱, 고무, 섬유 같은 고분자 소재를 다루는 학과예요. 합성부터 가공, 물성 평가까지 배웁니다.`}
  searchPlaceholder="개념 이름으로 검색 (예: 중합, 유리전이온도, 아라미드)"
  tracks={TRACKS}
  relatedMajors={RELATED_MAJORS}
/>
