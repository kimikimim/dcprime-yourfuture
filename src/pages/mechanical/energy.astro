---
import GlossaryLayout from '../../layouts/GlossaryLayout.astro';

const TRACKS = [
  {
    title: '에너지기계 / 열유체공학과',
    subtitle: 'Energy Machinery & Thermo-Fluid Engineering',
    careers: ['가전 기업(LG전자·삼성전자)', '엔지니어링 및 건설사(현대엔지니어링·삼성엔지니어링)', '발전공기업'],
    courses: [
      {
        name: '에너지기계 및 열유체공학',
        nameEn: 'Energy Machinery & Thermo-Fluid Engineering',
        year: '4학년 1학기',
        terms: [
          { ko: '공조냉동 (HVAC)', en: 'Heating, Ventilation & Air Conditioning', formula: 'COP = \\frac{Q_{cold}}{W_{in}}', desc: '냉매를 압축·팽창시키며 저온부에서 열을 흡수해 고온부로 방출하는 냉동사이클로 실내 온도를 조절하는 기술. 넣어준 일 $W_{in}$ 대비 옮긴 열량 $Q_{cold}$의 비율인 성능계수(COP)가 클수록 같은 냉방 효과를 더 적은 전력으로 얻는 효율적인 시스템.', example: '에어컨 에너지효율등급이 이 COP 값을 기준으로 매겨지는 것.' },
          { ko: '열교환기 설계', en: 'Heat Exchanger Design', desc: '고온·저온 두 유체를 얇은 금속판이나 관으로 분리한 채 맞흐름 또는 병행흐름으로 지나가게 해 열만 교환시키는 장치. 두 유체 온도차를 입구·출구에서 대수적으로 평균한 LMTD를 이용해 필요한 전열 면적과 유량을 계산해 설계함.', example: '발전소 응축기가 터빈을 통과한 증기를 냉각수로 다시 물로 되돌리는 열교환 과정.' },
          { ko: '가스터빈 및 발전설비', en: 'Gas Turbines & Power Generation Equipment', desc: '압축기로 공기를 고압으로 압축하고, 연소실에서 연료와 섞어 태워 고온·고압 가스를 만든 뒤, 그 가스가 터빈 블레이드를 밀어내며 회전력을 발생시켜 발전기를 돌리는 브레이턴 사이클 기반 설비. 배기가스의 남은 열로 증기를 만들어 다시 증기터빈을 돌리는 복합화력이 단일 사이클보다 효율이 훨씬 높음.', example: 'LNG 복합화력발전소가 가스터빈과 증기터빈을 이어붙여 효율을 높이는 방식.' },
          { ko: '전자기기 열관리', en: 'Thermal Management for Electronics', formula: 'R_{th} = \\Delta T / P', desc: '반도체 칩이 소모한 전력의 상당량이 열로 바뀌므로, 칩에서 방열판·냉각팬까지 이어지는 경로의 열저항 $R_{th}$을 최소화해 칩 온도를 안전 한계 이하로 유지하는 설계. 열저항이 낮을수록 같은 발열량에서도 온도 상승폭 $\\Delta T$이 작아짐.', example: '게이밍 노트북이 고성능 CPU·GPU의 발열을 히트파이프와 팬으로 식히는 냉각 설계.' },
          { ko: '열병합발전과 엑서지 효율', en: 'Combined Heat & Power (Cogeneration) & Exergy Efficiency', desc: '발전소가 전기만 생산하면 터빈을 돌리고 남은 배기열은 그냥 버려지는데, 이 폐열을 회수해 지역난방이나 공정용 증기로 함께 공급하면 하나의 연료로 전기와 열 두 가지 유용한 에너지를 동시에 얻어 전체 에너지 이용률을 80% 이상까지 끌어올릴 수 있음. 단순 열효율이 아니라 전기(고품질 에너지)와 열(상대적으로 저품질 에너지)의 질적 차이까지 반영하는 엑서지 효율로 평가해야 진짜 시스템 개선 효과를 정확히 판단할 수 있음.', example: '아파트 단지의 지역난방이 발전소에서 전기 생산 후 남은 열을 재활용해 공급되는 방식.' },
        ],
      },
    ],
  },
];

const RELATED_MAJORS = [
  { href: '/mechanical', title: '기계공학', subtitle: 'Mechanical Engineering' },
  { href: '/mechanical/automotive', title: '자동차공학/미래모빌리티', subtitle: 'Automotive Engineering' },
  { href: '/mechanical/robotics', title: '로봇공학/메카트로닉스', subtitle: 'Robotics & Mechatronics' },
  { href: '/mechanical/manufacturing', title: '정밀기계/생산', subtitle: 'Precision & Production' },
  { href: '/mechanical/naval', title: '조선해양공학', subtitle: 'Naval Architecture' },
];
---

<GlossaryLayout
  metaTitle="Your Future - 에너지기계공학 전공 맛보기 | 대치프라임"
  metaDescription="공조냉동, 발전설비, 열관리까지 에너지기계/열유체공학과 커리큘럼을 재구성한 전공 맛보기 페이지입니다."
  heading="에너지기계 / 열유체공학과"
  descriptionPrefix={`기계공학부 안에서 열과 유체를 다뤄 에너지를 만들고 관리하는 학과예요. 냉난방, 발전설비, 전자기기 열관리까지 폭넓게 다룹니다.`}
  searchPlaceholder="개념 이름으로 검색 (예: HVAC, 가스터빈, 열교환기)"
  tracks={TRACKS}
  relatedMajors={RELATED_MAJORS}
/>
