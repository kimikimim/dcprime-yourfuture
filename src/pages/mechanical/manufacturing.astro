---
import GlossaryLayout from '../../layouts/GlossaryLayout.astro';

const TRACKS = [
  {
    title: '정밀기계 / 생산공학과',
    subtitle: 'Precision Machinery & Production Engineering',
    careers: ['공작기계 제조사(DN솔루션즈)', '반도체·디스플레이 장비사(ASML·원익IPS)', '생산기술 연구소'],
    courses: [
      {
        name: '정밀기계 및 생산공학',
        nameEn: 'Precision Machinery & Production Engineering',
        year: '4학년 1학기',
        terms: [
          { ko: '컴퓨터지원제조', en: 'Computer-Aided Manufacturing (CAM)', desc: 'CAD로 설계한 3차원 형상 데이터를 소프트웨어가 분석해, 공구가 어떤 경로로 얼마나 깊이 얼마나 빠르게 이동해야 그 형상이 만들어지는지를 자동으로 계산해 공작기계용 명령어(G코드)로 변환하는 기술. 사람이 수천 줄의 좌표를 손으로 계산할 필요를 없애줌.', example: '자동차 금형처럼 복잡한 3차원 곡면을 CNC 밀링머신으로 자동 가공하도록 프로그래밍하는 것.' },
          { ko: '정밀가공학', en: 'Precision Machining', desc: '공작기계의 열변형, 진동, 공구 마모 등 미세한 오차 요인까지 통제해 마이크로미터(㎛), 나노미터급의 형상 정밀도로 부품을 가공하는 기술. 온도가 1도만 변해도 금속이 미세하게 팽창해 오차가 생기므로 항온 클린룸에서 작업하는 경우가 많음.', example: '반도체 노광장비 렌즈처럼 원자 수준의 표면 정밀도가 요구되는 부품 가공.' },
          { ko: '스마트팩토리 공정제어', en: 'Smart Factory Process Control', desc: '생산 라인 곳곳에 부착한 센서로 실시간 데이터를 수집해 PLC나 산업용 AI가 미리 정의된 로직에 따라 설비를 자동 조정하고, 불량 징후를 사전에 예측해 정지시키는 자동화 시스템.', example: '반도체 공장이 웨이퍼 이상 신호를 실시간 감지해 불량 발생 전에 공정을 자동 조정하는 것.' },
          { ko: '나노정밀측정', en: 'Nano-Precision Metrology', desc: '레이저 간섭계, 원자현미경(AFM) 등을 이용해 나노미터 단위의 미세한 치수·형상·표면 거칠기까지 정확하게 측정하는 계측 기술. 아무리 정밀하게 가공해도 이를 검증할 계측 기술이 없으면 정밀 가공 자체가 무의미해짐.', example: '반도체 웨이퍼 표면의 원자 몇 개 수준 요철을 측정해 공정 이상을 검출하는 것.' },
          { ko: 'AI 기반 예지보전', en: 'AI-Based Predictive Maintenance', desc: '설비가 완전히 고장 난 뒤에 고치는 사후 정비나, 일정 주기마다 무조건 부품을 교체하는 예방 정비 대신, 진동·온도·전류 센서 데이터의 미세한 패턴 변화를 머신러닝 모델이 학습해 실제 고장이 나기 며칠~몇 주 전에 이상 징후를 미리 예측하고 정비 시점을 알려주는 기법. 불필요한 조기 교체 비용과 갑작스러운 정지로 인한 손실을 동시에 줄일 수 있음.', example: '공작기계의 베어링 진동 패턴 변화를 AI가 감지해 마모로 인한 고장을 사전에 경고하는 것.' },
        ],
      },
    ],
  },
];

const RELATED_MAJORS = [
  { href: '/mechanical', title: '기계공학', subtitle: 'Mechanical Engineering' },
  { href: '/mechanical/automotive', title: '자동차공학/미래모빌리티', subtitle: 'Automotive Engineering' },
  { href: '/mechanical/robotics', title: '로봇공학/메카트로닉스', subtitle: 'Robotics & Mechatronics' },
  { href: '/mechanical/energy', title: '에너지기계/열유체', subtitle: 'Energy & Thermo-Fluid' },
  { href: '/mechanical/naval', title: '조선해양공학', subtitle: 'Naval Architecture' },
];
---

<GlossaryLayout
  metaTitle="Your Future - 정밀기계공학 전공 맛보기 | 대치프라임"
  metaDescription="CAM, 정밀가공, 스마트팩토리까지 정밀기계/생산공학과 커리큘럼을 재구성한 전공 맛보기 페이지입니다."
  heading="정밀기계 / 생산공학과"
  descriptionPrefix={`기계공학부 안에서 부품을 정밀하게 가공하고 생산 공정을 설계하는 학과예요. 반도체·디스플레이 장비 산업과도 밀접합니다.`}
  searchPlaceholder="개념 이름으로 검색 (예: CAM, 정밀가공, 스마트팩토리)"
  tracks={TRACKS}
  relatedMajors={RELATED_MAJORS}
/>
