---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

interface Term {
  ko: string;
  en: string;
  formula?: string;
  desc: string;
}

interface Course {
  name: string;
  nameEn: string;
  year: string;
  terms: Term[];
}

interface Track {
  title: string;
  subtitle: string;
  courses: Course[];
  careers?: string[];
}

interface RelatedMajor {
  href: string;
  title: string;
  subtitle: string;
}

interface Props {
  metaTitle: string;
  metaDescription: string;
  eyebrow?: string;
  heading: string;
  descriptionPrefix: string;
  searchPlaceholder: string;
  tracks: Track[];
  careers?: string[];
  relatedMajors?: RelatedMajor[];
}

const {
  metaTitle,
  metaDescription,
  eyebrow = 'Your Future',
  heading,
  descriptionPrefix,
  searchPlaceholder,
  tracks,
  careers,
  relatedMajors,
} = Astro.props;

const totalCourseCount = tracks.reduce((sum, t) => sum + t.courses.length, 0);
const totalTermCount = tracks.reduce((sum, t) => sum + t.courses.reduce((s, c) => s + c.terms.length, 0), 0);
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon-circle.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{metaTitle}</title>
    <meta name="description" content={metaDescription} />
    <meta name="robots" content="index, follow" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css">
  </head>
  <body class="bg-gray-50 font-sans">

    <SiteHeader backHref="/" backLabel="Your Future 홈으로 →" />

    <div class="min-h-screen">
      <div class="border-b border-gray-200 bg-white">
        <div class="container mx-auto px-4 py-8 sm:py-10">
          <p class="text-sm text-brand font-semibold mb-1">{eyebrow}</p>
          <h1 class="text-xl sm:text-2xl md:text-3xl font-bold text-gray-900">{heading}</h1>
          <p class="text-sm text-gray-500 mt-2 leading-relaxed">
            {descriptionPrefix} 과목 {totalCourseCount}개 · 개념 {totalTermCount}개.
          </p>
          {careers && careers.length > 0 && (
            <div class="mt-4 flex flex-wrap items-center gap-2">
              <span class="text-xs font-semibold text-gray-400 mr-1">진로</span>
              {careers.map((c) => (
                <span class="text-xs text-brand-dark bg-brand-light px-2.5 py-1 rounded-full">{c}</span>
              ))}
            </div>
          )}
        </div>
      </div>

      {relatedMajors && relatedMajors.length > 0 && (
        <div class="border-b border-gray-200 bg-white">
          <div class="container mx-auto px-4 py-4 sm:py-5">
            <p class="text-xs font-semibold text-gray-400 mb-3">관련 학과</p>
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
              {relatedMajors.map((m) => (
                <a
                  href={m.href}
                  class="block bg-gray-50 rounded-lg border border-gray-100 px-3 py-2.5 hover:border-brand hover:bg-brand-light transition-colors"
                >
                  <p class="text-sm font-bold text-gray-900">{m.title}</p>
                  <p class="text-[10px] text-gray-400">{m.subtitle}</p>
                </a>
              ))}
            </div>
          </div>
        </div>
      )}

      <div class="sticky top-0 z-40 bg-white border-b border-gray-200">
        <div class="container mx-auto px-4 py-3 sm:py-4">
          <div class="relative max-w-xl">
            <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            <input
              id="term-search"
              type="text"
              placeholder={searchPlaceholder}
              class="w-full pl-11 pr-4 py-2.5 sm:py-3 rounded-lg border border-gray-200 text-sm focus:outline-none focus:border-brand"
            />
          </div>
          <p id="search-empty" class="hidden text-sm text-gray-400 mt-3">검색 결과가 없습니다.</p>
        </div>
      </div>

      <div class="container mx-auto px-4 py-8 sm:py-10 max-w-5xl">
        {tracks.map((track) => (
          <div class="track-block mb-10">
            <div class="mb-4">
              <h2 class="text-base sm:text-lg font-bold text-gray-900">{track.title}</h2>
              <p class="text-xs text-gray-400">{track.subtitle}</p>
              {track.careers && track.careers.length > 0 && (
                <div class="mt-2 flex flex-wrap items-center gap-1.5">
                  <span class="text-[10px] font-semibold text-gray-400 mr-0.5">진로</span>
                  {track.careers.map((c) => (
                    <span class="text-[10px] text-brand-dark bg-brand-light px-2 py-0.5 rounded-full">{c}</span>
                  ))}
                </div>
              )}
            </div>
            <div class="space-y-3">
              {track.courses.map((course) => (
                <details class="course-block group bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden">
                  <summary class="list-none [&::-webkit-details-marker]:hidden flex items-center justify-between gap-3 px-4 py-3 sm:px-5 sm:py-4 cursor-pointer select-none hover:bg-gray-50 transition-colors">
                    <div class="min-w-0">
                      <div class="flex items-center gap-2 flex-wrap">
                        <span class="text-sm sm:text-base font-bold text-gray-900">{course.name}</span>
                        <span class="text-[10px] sm:text-xs text-brand bg-brand-light px-2 py-0.5 rounded-full shrink-0">{course.year}</span>
                      </div>
                      <p class="text-xs text-gray-400 mt-0.5">{course.nameEn}</p>
                    </div>
                    <div class="flex items-center gap-2 shrink-0 text-gray-400">
                      <span class="text-xs hidden sm:inline">{course.terms.length}개 개념</span>
                      <svg class="w-4 h-4 transition-transform duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                      </svg>
                    </div>
                  </summary>
                  <div class="border-t border-gray-100 px-4 py-4 sm:px-5 sm:py-5 grid sm:grid-cols-2 gap-3">
                    {course.terms.map((t) => (
                      <div
                        class="term-card bg-gray-50 rounded-lg border border-gray-100 p-4"
                        data-search={`${t.ko} ${t.en} ${t.desc}`.toLowerCase()}
                      >
                        <p class="text-sm font-bold text-gray-900">{t.ko}</p>
                        <p class="text-xs text-gray-400 mb-2">{t.en}</p>
                        {t.formula && (
                          <div class="katex-formula text-sm text-brand my-2 overflow-x-auto" data-formula={t.formula}></div>
                        )}
                        <p class="text-sm text-gray-600 leading-relaxed" set:html={t.desc.replace(/\$([^$]+)\$/g, '<span class="katex-inline" data-formula="$1"></span>')} />
                      </div>
                    ))}
                  </div>
                </details>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

    <SiteFooter />

    <script>
      async function loadKatex() {
        if ((window as any).katex) return;
        await new Promise<void>((resolve, reject) => {
          const script = document.createElement('script');
          script.src = 'https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.js';
          script.onload = () => resolve();
          script.onerror = reject;
          document.head.appendChild(script);
        });
      }

      async function renderFormulas() {
        await loadKatex();
        const katex = (window as any).katex;
        if (!katex) return;
        document.querySelectorAll<HTMLElement>('.katex-formula, .katex-inline').forEach(el => {
          const formula = el.dataset.formula;
          if (!formula) return;
          try {
            katex.render(formula, el, { throwOnError: false, displayMode: el.classList.contains('katex-formula') });
          } catch {
            el.textContent = formula;
          }
        });
      }

      function initSearch() {
        const input = document.getElementById('term-search') as HTMLInputElement | null;
        const emptyMsg = document.getElementById('search-empty');
        if (!input) return;

        input.addEventListener('input', () => {
          const q = input.value.trim().toLowerCase();
          let anyVisible = false;

          document.querySelectorAll<HTMLElement>('.track-block').forEach(track => {
            let trackHasMatch = false;

            track.querySelectorAll<HTMLDetailsElement>('.course-block').forEach(course => {
              let courseHasMatch = false;

              course.querySelectorAll<HTMLElement>('.term-card').forEach(card => {
                const match = !q || (card.dataset.search ?? '').includes(q);
                card.classList.toggle('hidden', !match);
                if (match) courseHasMatch = true;
              });

              course.classList.toggle('hidden', !courseHasMatch);
              course.open = q ? courseHasMatch : false;
              if (courseHasMatch) trackHasMatch = true;
            });

            track.classList.toggle('hidden', !trackHasMatch);
            if (trackHasMatch) anyVisible = true;
          });

          emptyMsg?.classList.toggle('hidden', anyVisible || !q);
        });
      }

      renderFormulas();
      initSearch();
    </script>
  </body>
</html>
